<style>
  [data-agenda-item-card] {
    background-color: var(--bg-normal);
    transition:
      background-color 0.15s ease,
      box-shadow 0.15s ease,
      transform 0.15s ease;
  }

  [data-agenda-item-card]:hover {
    background-color: var(--bg-hover);
  }

  [data-agenda-item-card].is-selected {
    background-color: var(--bg-hover);
    transform: translateX(10px);
  }
</style>

<div
  class="h-full w-full flex flex-col rounded-2xl overflow-hidden
         shadow-xl shadow-black/50
         <%= @class_name %>"
  style="border: 1px solid var(--studs-border);"
  data-controller="<%= @controller %>"
  data-agenda-count="<%= agenda_count %>"
>

  <% theme = helpers.try(:current_user)&.theme%>
  <% header_style =
    if %w[nebula aurora sunset].include?(theme)
      # Uses different colors for visibility on Agenda Page
      "background-color: color-mix(in srgb, var(--studs-accent) 12%, var(--studs-sidebar-bg) 88%);"
    end %>
  <% header_attrs = { class: "px-4 py-3 studs-topbar" } %>
  <% header_attrs[:style] = header_style if header_style.present? %>
  <%= tag.div(**header_attrs) do %>
    <div class="flex items-center justify-between">
      <div class="min-w-0">
        <div class="text-sm font-semibold text-zinc-100">
          <%= @title %>
        </div>
        <div class="mt-0.5 text-xs text-zinc-400">
          <%= subtitle_text %>
        </div>
      </div>
    </div>
  <% end %>

  <div class="flex-1 min-h-0 bg-zinc-950/95">
    <div class="h-full overflow-auto px-3 py-3">
      <% if items.any? %>
        <div class="space-y-2">
          <%= safe_join(items) %>
        </div>
      <% else %>
        <div class="rounded-2xl border bg-zinc-900/40 px-4 py-4 text-sm text-zinc-200"
             style="border-color: var(--studs-border);">
          <%= @empty_message %>
        </div>
      <% end %>
    </div>
  </div>
</div>
