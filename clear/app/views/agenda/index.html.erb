<% content_for :page_title, "Agenda" %>
<% content_for :page_subtitle, "Upcoming tasks" %>
<% today = Time.zone.today %>
<% entries = (@paged_agenda_by_date || {})[today] || [] %>
<% active_filters = [params.dig(:q, :term), params[:type], params[:start_date], params[:end_date]].compact.count(&:present?) %>
<% entries_by_date =
  if active_filters.positive?
    (@paged_agenda_by_date || {}).sort_by { |date, _| date }.to_h
  elsif entries.any?
    { today => entries }
  else
    {}
  end %>

<div class="space-y-4">
  <%= form_with url: agenda_index_path,
                method: :get,
                data: {
                  controller: "search agenda-reset-filters",
                  search_target: "form",
                  turbo_frame: "agenda_list"
                },
                html: { class: "space-y-3" } do |f| %>
    <div class="flex flex-wrap items-center gap-2 rounded-2xl p-2"
         style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg-2);">
      <div class="min-w-[180px] grow shrink basis-[260px]">
        <%= render Studs::SearchBarComponent.new(
          name: "q[term]",
          value: params.dig(:q, :term),
          placeholder: "Search by filter option (first button to the right)…",
          class_name: "w-full",
          data: {
            search_target: "input",
            action: "input->search#search input->agenda-reset-filters#update keydown->search#submit keydown->agenda-reset-filters#update"
          }
        ) %>
      </div>
      <div class="mx-1 hidden h-5 w-px rounded-full md:block" style="background-color: var(--studs-border);"></div>
      <div class="w-40">
        <div data-action="dropdown:select->search#search dropdown:select->agenda-reset-filters#update">
          <%= render Studs::DropdownComponent.new(
            label: "Name",
            variant: :agenda_filter,
            name: "q[field]",
            selected_value: params.dig(:q, :field).presence || "name",
            items: [
              { label: "Name", value: "name" },
              { label: "Location", value: "location" },
              { label: "Description", value: "description" }
            ]
          ) %>
        </div>
      </div>
      <div class="mx-1 hidden h-5 w-px rounded-full md:block" style="background-color: var(--studs-border);"></div>
      <div class="w-36">
        <div data-action="dropdown:select->search#search dropdown:select->agenda-reset-filters#update">
          <%= render Studs::DropdownComponent.new(
            label: "All Types",
            variant: :agenda_filter,
            name: "type",
            selected_value: params[:type],
            items: [
              { label: "All Types", value: "" },
              { label: "Events", value: "event" },
              { label: "Courses", value: "course" },
              { label: "Course Items", value: "course_item" },
              { label: "Work Shifts", value: "work_shift" }
            ]
          ) %>
        </div>
      </div>
      <div class="mx-1 hidden h-5 w-px rounded-full md:block" style="background-color: var(--studs-border);"></div>
      <div class="shrink-0 flex items-center gap-2">
        <%= f.date_field :start_date,
          value: params[:start_date],
          placeholder: "Start",
          class: "h-[38px] w-36 rounded-xl border bg-zinc-900/50 px-3 py-2 text-sm text-zinc-200 focus:outline-none focus:ring-2 transition-all",
          style: "border-color: var(--studs-border); --tw-ring-color: var(--studs-accent);",
          data: { action: "change->search#search change->agenda-reset-filters#update" } %>
        <span class="text-sm text-zinc-500 font-medium select-none">:</span>
        <%= f.date_field :end_date,
          value: params[:end_date],
          placeholder: "End",
          class: "h-[38px] w-36 rounded-xl border bg-zinc-900/50 px-3 py-2 text-sm text-zinc-200 focus:outline-none focus:ring-2 transition-all",
          style: "border-color: var(--studs-border); --tw-ring-color: var(--studs-accent);",
          data: { action: "change->search#search change->agenda-reset-filters#update" } %>
      </div>
      <div data-agenda-reset-filters-target="reset" class="<%= active_filters.positive? ? '' : 'hidden' %> contents">
        <div class="mx-1 hidden h-5 w-px rounded-full md:block" style="background-color: var(--studs-border);"></div>
        <%= link_to "Reset Filters",
          agenda_index_path,
          class: "studs-btn-accent shrink-0" %>
      </div>
    </div>
  <% end %>

  <%= turbo_frame_tag "agenda_list" do %>
    <%= render "agenda/list_frame",
      entries_by_date: entries_by_date,
      active_filters: active_filters %>
  <% end %>
</div>
