<% reason = local_assigns[:reason] %>
<div class="flex items-start justify-start ai-chat-pop mt-4">
  <div class="self-start inline-flex flex-col w-full max-w-[62%] rounded-2xl px-4 py-3 text-sm leading-relaxed"
       style="background-color: var(--studs-panel-bg-2); border: 1px solid var(--studs-border); color: #f4f4f5;">
    <div class="mb-1.5">
      <span class="text-[10px] font-bold uppercase tracking-widest"
            style="color: color-mix(in srgb, var(--studs-accent) 60%, #a1a1aa);">Assistant</span>
    </div>

    <% if reason == :only_proposed %>
      <p class="prose prose-invert prose-sm max-w-none mb-3">
        You have proposed availability blocks waiting — accept them first, then I can schedule your tasks into them.
      </p>
      <%= link_to "Review my blocks", blocks_path, data: { turbo_frame: "_top" },
            class: "w-full inline-flex items-center justify-center rounded-2xl px-3 py-1.5 border",
            style: "border-color: var(--studs-border); background-color: color-mix(in srgb, var(--studs-panel-bg) 55%, #09090b); color: #f4f4f5; font-size: 0.875rem;" %>
    <% else %>
      <p class="prose prose-invert prose-sm max-w-none mb-3">
        You don't have any availability blocks yet — those are the windows I schedule your tasks into. I can propose a starter routine you can tweak.
      </p>
      <%= button_to "Set up my blocks", ai_chat_index_path,
            params: { content: "Set up a starter study routine for me — about 8 hours of study time per week in the afternoons.", history: "[]" },
            form: { data: { turbo_stream: true } },
            class: "w-full inline-flex items-center justify-center rounded-2xl px-3 py-1.5 border",
            style: "border-color: var(--studs-border); background-color: color-mix(in srgb, var(--studs-panel-bg) 55%, #09090b); color: #f4f4f5; font-size: 0.875rem;" %>
    <% end %>
  </div>
</div>
