<%= turbo_frame_tag "event_drawer" do %>
  <% draft_course_item_confirm = current_user_draft.present? ? "This action will affect your main calendar. Will you like to continue?" : nil %>
  <% color = course.color.presence || "#34D399" %>
  <% due_line =
      if course_item.due_at.present?
        "Due #{course_item.due_at.in_time_zone.strftime("%A, %b %-d · %-I:%M %p")}"
      else
        "No due date"
      end
  %>

  <div class="flex h-full flex-col">
    <div class="flex items-start justify-between border-b border-zinc-800 px-6 py-4">
      <div class="min-w-0">
        <div class="flex items-center gap-2">
          <span class="h-3 w-3 rounded-full" style="background-color: <%= color %>"></span>
          <div class="text-sm font-semibold text-zinc-100 truncate">
            <%= course_item.title.presence || "(Untitled)" %>
          </div>
        </div>
        <div class="mt-1 text-xs text-zinc-500">Course item details</div>
      </div>

      <button
        type="button"
        data-action="drawer#close"
        class="studs-nav-btn">
        ✕
      </button>
    </div>

    <div class="scrollbars min-h-0 flex-1 overflow-y-auto px-6 py-6 space-y-4">
      <div class="rounded-2xl border border-zinc-800 bg-zinc-950/40 p-4">
        <div class="text-xs text-zinc-400">Type</div>
        <div class="mt-1 text-sm text-zinc-100"><%= course_item.kind.humanize %></div>
      </div>

      <div class="rounded-2xl border border-zinc-800 bg-zinc-950/40 p-4">
        <div class="text-xs text-zinc-400">When</div>
        <div class="mt-1 text-sm text-zinc-100"><%= due_line %></div>
      </div>

      <div class="rounded-2xl border border-zinc-800 bg-zinc-950/40 p-4">
        <div class="text-xs text-zinc-400">Course</div>
        <div class="mt-1 text-sm text-zinc-100"><%= course.title.presence || "Untitled Course" %></div>
      </div>

      <div class="rounded-2xl border border-zinc-800 bg-zinc-950/40 p-4">
        <div class="text-xs text-zinc-400">Details</div>
        <div class="mt-1 text-sm text-zinc-100 whitespace-pre-wrap"><%= course_item.details.presence || "—" %></div>
      </div>

      <% if course.location.present? %>
        <div class="rounded-2xl border border-zinc-800 bg-zinc-950/40 p-4">
          <div class="text-xs text-zinc-400">Course location</div>
          <div class="mt-1 text-sm text-zinc-100"><%= course.location %></div>
        </div>
      <% end %>

      <% if course.professor.present? %>
        <div class="rounded-2xl border border-zinc-800 bg-zinc-950/40 p-4">
          <div class="text-xs text-zinc-400">Professor</div>
          <div class="mt-1 text-sm text-zinc-100"><%= course.professor %></div>
        </div>
      <% end %>

    </div>

    <div class="shrink-0 border-t border-zinc-800 bg-zinc-950/60 px-6 py-4">
      <div class="flex items-center justify-between gap-3">
        <div class="flex items-center gap-2">
          <%= link_to edit_course_course_item_path(course, course_item),
                      data: { turbo_frame: "event_drawer", turbo_prefetch: false, turbo_confirm: draft_course_item_confirm }.compact,
                      class: "studs-nav-btn" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
            Edit
          <% end %>

          <%= button_to course_course_item_path(course, course_item),
                method: :delete,
                class: "studs-nav-btn",
                style: "border-color: rgba(239,68,68,0.4); color: #fca5a5;",
                form: { data: { turbo_confirm: (draft_course_item_confirm || "Delete \"#{course_item.title}\"?") } } do %>
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
            Delete
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>
