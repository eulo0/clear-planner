<% label_classes = "block text-[10px] font-bold uppercase tracking-widest mb-1.5" %>
<% label_style   = "color: var(--studs-accent); opacity: 0.8;" %>
<% input_classes = "w-full rounded-2xl px-4 py-2.5 text-sm text-zinc-100 placeholder:text-zinc-600 " \
                   "bg-zinc-950/60 focus:outline-none focus:ring-2 transition-all duration-150 border" %>
<% input_style   = "border-color: var(--studs-border); --tw-ring-color: var(--studs-accent);" %>
<% cancel_drawer = local_assigns[:cancel_drawer] %>
<% draft_course_item_confirm = current_user_draft.present? ? "This action will affect your main calendar. Will you like to continue?" : nil %>
<%= form_with model: [course, course_item], data: (draft_course_item_confirm ? { turbo_confirm: draft_course_item_confirm } : {}) do |f| %>
  <% if course_item.errors.any? %>
    <div class="rounded-2xl p-4 text-red-300 mb-4"
         style="border: 1px solid rgba(239,68,68,0.3); background-color: rgba(127,29,29,0.2);">
      <p class="text-sm font-semibold mb-1">Please fix the following:</p>
      <ul class="list-disc pl-5 text-sm space-y-0.5">
        <% course_item.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div class="grid gap-4 md:grid-cols-6 items-end">
    <div class="md:col-span-6">
      <%= f.label :title, class: label_classes, style: label_style do %>Title <span class="text-red-400">*</span><% end %>
      <%= f.text_field :title,
            placeholder: "HW 3, Midterm, Seminar…",
            class: input_classes,
            style: input_style %>
    </div>
    <div class="md:col-span-3">
      <%= f.label :kind, class: label_classes, style: label_style do %>Type <span class="text-red-400">*</span><% end %>
      <%= f.select :kind,
            CourseItem.kinds.keys.map { |k| [k.humanize, k] },
            {},
            class: input_classes,
            style: input_style %>
    </div>
    <div class="md:col-span-3">
      <%= f.label :due_at, "Due", class: label_classes, style: label_style %>
      <%= f.datetime_local_field :due_at,
            class: input_classes,
            style: input_style %>
    </div>
    <div class="md:col-span-6">
      <%= f.label :details, "Details", class: label_classes, style: label_style %>
      <%= f.text_area :details, rows: 3,
            class: input_classes,
            style: "#{input_style} resize: vertical;" %>
    </div>
    <div class="md:col-span-6 flex items-center gap-3 pt-2" style="border-top: 1px solid var(--studs-divider);">
      <button type="submit" class="studs-btn-accent">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
        </svg>
        <%= course_item.persisted? ? "Save changes" : "Add item" %>
      </button>
      <% if course_item.persisted? %>
        <% if cancel_drawer %>
          <button type="button" class="studs-nav-btn" data-action="drawer#close">Cancel</button>
        <% else %>
          <%= link_to "Cancel", course_course_items_path(course), class: "studs-nav-btn" %>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>
