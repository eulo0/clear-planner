<%= turbo_frame_tag "event_popover" do %>
  <% draft_course_item_confirm = current_user_draft.present? ? "This action will affect your main calendar. Will you like to continue?" : nil %>
  <% color = course.color.presence || "#34D399" %>

  <!-- Header -->
  <div class="flex items-center justify-between gap-3 px-4 pt-3 pb-2">
    <div class="flex items-center gap-2 min-w-0">
      <span class="h-3 w-3 shrink-0 rounded-full" style="background-color:<%= color %>"></span>
      <div class="text-sm font-semibold text-zinc-100 truncate">
        <%= course_item.title %>
      </div>
    </div>
    <button
      type="button"
      data-action="event-popover#close"
      class="shrink-0 inline-flex items-center justify-center h-6 w-6 rounded-lg text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800 transition text-xs">
      ✕
    </button>
  </div>

  <!-- Details -->
  <div class="px-4 pb-3 space-y-2 text-sm">
    <!-- Type badge -->
    <div class="flex items-center gap-2">
      <span class="inline-flex items-center rounded-md px-2 py-0.5 text-xs font-semibold"
            style="background-color: <%= color %>22; color: <%= color %>; border: 1px solid <%= color %>44;">
        <%= course_item.kind.humanize %>
      </span>
      <span class="text-zinc-500 text-xs"><%= course.title %></span>
    </div>

    <!-- Due date -->
    <div class="flex items-center gap-2 text-zinc-300">
      <svg class="h-4 w-4 shrink-0 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <span><%= course_item.due_at ? "Due #{course_item.due_at.in_time_zone.strftime("%A, %b %-d · %-I:%M %p")}" : "No due date" %></span>
    </div>

    <% if course_item.details.present? %>
      <div class="flex items-start gap-2 text-zinc-300">
        <svg class="h-4 w-4 shrink-0 mt-0.5 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h10"/>
        </svg>
        <span class="line-clamp-3 whitespace-pre-wrap"><%= course_item.details %></span>
      </div>
    <% end %>
  </div>

  <!-- Actions -->
  <div class="flex items-center gap-2 px-4 pb-3 pt-1 border-t border-zinc-800">
    <%= link_to edit_course_course_item_path(course, course_item),
          data: { turbo: false, turbo_confirm: draft_course_item_confirm }.compact,
          class: "inline-flex items-center gap-1.5 rounded-lg px-3 py-1.5 text-sm text-zinc-200 hover:bg-zinc-800 transition" do %>
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
      </svg>
      Edit
    <% end %>

    <%= button_to course_course_item_path(course, course_item),
          method: :delete,
          class: "inline-flex items-center gap-1.5 rounded-lg px-3 py-1.5 text-sm text-rose-300 hover:bg-rose-950/40 transition",
          form: { data: { turbo_confirm: (draft_course_item_confirm || "Delete \"#{course_item.title}\"?") } } do %>
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
      </svg>
      Delete
    <% end %>
  </div>
<% end %>
