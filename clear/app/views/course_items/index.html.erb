<% content_for :page_title, (@course.title.presence || "Course") %>
<% content_for :page_subtitle, "Course items" %>
<% color = @course.try(:color).presence || "#34D399" %>
<% draft_course_item_confirm = current_user_draft.present? ? "This action will affect your main calendar. Will you like to continue?" : nil %>
<div class="rounded-2xl p-6 space-y-5" style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg);">
  <!-- Header -->
  <div class="flex items-center justify-between gap-4">
    <div class="min-w-0 flex-1">
      <div class="text-base font-semibold text-zinc-100 truncate"><%= @course.title.presence || "Course" %></div>
      <div class="text-sm text-zinc-500">Add and manage assignments, exams, presentations, and more.</div>
    </div>
    <%= link_to courses_path, class: "studs-nav-btn shrink-0" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      Back to courses
    <% end %>
  </div>
  <!-- Add item form -->
  <div class="rounded-2xl p-4" style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg-2);">
    <div class="text-[10px] font-bold uppercase tracking-widest mb-3" style="color: var(--studs-accent); opacity: 0.8;">New item</div>
    <%= render "form", course: @course, course_item: @course_item %>
  </div>
  <!-- Items list -->
  <div class="overflow-hidden rounded-2xl" style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg-2);">
    <% if @course_items.any? %>
      <% @course_items.each_with_index do |item, i| %>
        <div class="flex items-start justify-between gap-4 p-4"
             style="border-left: 4px solid <%= color %>;
                    <%= i > 0 ? "border-top: 1px solid var(--studs-divider);" : "" %>">
          <div class="min-w-0 flex-1">
            <p class="font-medium text-zinc-100 truncate"><%= item.title.presence || "(Untitled)" %></p>
            <p class="mt-1 text-sm text-zinc-400">
              <span class="inline-block rounded px-1.5 py-0.5 text-[10px] font-semibold mr-1"
                    style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-hover); color: var(--studs-accent);">
                <%= item.kind.humanize %>
              </span>
              <%= item.due_at ? "Due #{l(item.due_at)}" : "No due date" %>
            </p>
            <% if item.details.present? %>
              <p class="mt-1 text-sm text-zinc-500 whitespace-pre-line"><%= item.details %></p>
            <% end %>
          </div>
          <div class="flex shrink-0 items-center gap-1.5">
            <%= link_to edit_course_course_item_path(@course, item), class: "studs-nav-btn", data: { turbo_confirm: draft_course_item_confirm }.compact do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
              Edit
            <% end %>
            <%= button_to course_course_item_path(@course, item),
                  method: :delete,
                  form: { data: { turbo_confirm: (draft_course_item_confirm || "Delete this item?") } },
                  class: "studs-nav-btn",
                  style: "border-color: rgba(239,68,68,0.4); color: #fca5a5;" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
              </svg>
              Delete
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="flex flex-col items-center justify-center py-16 text-center">
        <div class="mb-3 opacity-30"><%= icon "task-done-01-stroke-rounded", class: "h-10 w-10 text-zinc-300" %></div>
        <p class="text-sm font-medium text-zinc-300">No items yet</p>
        <p class="mt-1 text-xs text-zinc-500">Add your first assignment, exam, or other item above</p>
      </div>
    <% end %>
  </div>
</div>
