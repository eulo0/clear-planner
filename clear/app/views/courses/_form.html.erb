<% start_date_param = local_assigns[:start_date].presence || params[:start_date].presence %>
<% turbo_enabled = local_assigns.key?(:turbo) ? local_assigns[:turbo] : true %>
<% cancel_drawer = local_assigns[:cancel_drawer] %>
<% course_identifier = local_assigns[:course_identifier] %>
<% draft_temp_course = course_identifier.to_s.start_with?("d_") %>
<% form_url =
    if draft_temp_course
      start_date_param ? course_path(course_identifier, start_date: start_date_param) : course_path(course_identifier)
    elsif course.persisted?
      start_date_param ? course_path(course, start_date: start_date_param) : course_path(course)
    else
      start_date_param ? courses_path(start_date: start_date_param) : courses_path
    end
%>
<%= form_with model: course,
              url: form_url,
              method: (draft_temp_course ? :patch : nil),
              class: "space-y-5",
              data: { turbo: turbo_enabled, controller: "duration-fill" } do |f| %>
  <%= hidden_field_tag :start_date, start_date_param if start_date_param.present? %>
  <% if course.errors.any? %>
    <div class="rounded-2xl p-4 text-red-300"
         style="border: 1px solid rgba(239,68,68,0.3); background-color: rgba(127,29,29,0.2);">
      <p class="text-sm font-semibold mb-1">Please fix the following:</p>
      <ul class="list-disc pl-5 text-sm space-y-0.5">
        <% course.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <% label_classes = "block text-[10px] font-bold uppercase tracking-widest mb-1.5" %>
  <% label_style   = "color: var(--studs-accent); opacity: 0.8;" %>
  <% input_classes = "w-full rounded-2xl px-4 py-2.5 text-sm text-zinc-100 placeholder:text-zinc-600 " \
                     "bg-zinc-950/60 focus:outline-none focus:ring-2 transition-all duration-150 border" %>
  <% input_style   = "border-color: var(--studs-border); --tw-ring-color: var(--studs-accent);" %>
  <!-- Course name -->
  <div>
    <%= f.label :title, class: label_classes, style: label_style do %>Course name <span class="text-red-400">*</span><% end %>
    <%= f.text_field :title,
          class: input_classes,
          style: input_style,
          placeholder: "e.g. ENGL 1013 - Freshman Composition I…" %>
  </div>
  <!-- Times -->
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    <div>
      <%= f.label :start_time, class: label_classes, style: label_style do %>Start time <span class="text-red-400">*</span><% end %>
      <%= f.time_field :start_time, class: input_classes, style: input_style,
            data: { duration_fill_target: "startField", action: "change->duration-fill#fill" } %>
    </div>
    <div>
      <%= f.label :end_time, class: label_classes, style: label_style do %>End time <span class="text-red-400">*</span><% end %>
      <%= f.time_field :end_time, class: input_classes, style: input_style,
            data: { duration_fill_target: "endField", action: "change->duration-fill#reverseFill" } %>
    </div>
  </div>
  <!-- Duration -->
  <div>
    <%= f.label :duration_minutes, "Duration", class: label_classes, style: label_style %>
    <div data-action="dropdown:select->duration-fill#fill">
      <%= render Studs::DropdownComponent.new(
        label: "— select duration —",
        variant: :duration,
        name: "#{f.object_name}[duration_minutes]",
        selected_value: course.duration_minutes,
        items: ApplicationHelper::DURATION_OPTIONS.map { |label, value| { label: label, value: value.to_s } }
      ) %>
    </div>
  </div>
  <!-- Dates -->
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    <div>
      <%= f.label :start_date, class: label_classes, style: label_style do %>Start date <span class="text-red-400">*</span><% end %>
      <%= f.date_field :start_date, class: input_classes, style: input_style %>
    </div>
    <div>
      <%= f.label :end_date, class: label_classes, style: label_style do %>End date <span class="text-red-400">*</span><% end %>
      <%= f.date_field :end_date, class: input_classes, style: input_style %>
    </div>
  </div>
  <!-- Term -->
  <div>
    <%= f.label :term, "Term", class: label_classes, style: label_style %>
    <%= f.text_field :term,
          class: input_classes,
          style: input_style,
          placeholder: "e.g. Fall 2025, Spring 2026…" %>
  </div>
  <!-- Professor + Location -->
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    <div>
      <%= f.label :professor, "Professor", class: label_classes, style: label_style %>
      <%= f.text_field :professor, class: input_classes, style: input_style %>
    </div>
    <div>
      <%= f.label :location, "Location", class: label_classes, style: label_style %>
      <%= f.text_field :location,
            class: input_classes,
            style: input_style,
            placeholder: "e.g. IESB 220, NETH 153" %>
    </div>
  </div>
  <!-- Office + Office hours -->
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    <div>
      <%= f.label :office, "Office", class: label_classes, style: label_style %>
      <%= f.text_field :office,
            class: input_classes,
            style: input_style,
            placeholder: "e.g. IESB 216" %>
    </div>
    <div>
      <%= f.label :office_hours, "Office hours", class: label_classes, style: label_style %>
      <%= f.text_field :office_hours,
            class: input_classes,
            style: input_style,
            placeholder: "e.g. MW 1:00 - 3:00 pm" %>
    </div>
  </div>
  <!-- Description -->
  <div>
    <%= f.label :description, "Description", class: label_classes, style: label_style %>
    <%= f.text_area :description,
          rows: 3,
          class: input_classes,
          style: "#{input_style} resize: vertical;",
          placeholder: "Course details…" %>
  </div>
  <!-- Repeat days + Color -->
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 items-start">
    <!-- Repeat card -->
    <div class="rounded-2xl p-4"
         style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg-2);">
      <div class="text-sm font-semibold text-zinc-200">Repeat days <span class="text-red-400">*</span></div>
      <div class="text-xs text-zinc-500 mt-0.5 mb-4">Select which weekdays this course meets</div>
      <div class="text-[10px] font-bold uppercase tracking-widest mb-2"
           style="color: var(--studs-accent); opacity: 0.8;">Days</div>
      <div class="grid grid-cols-7 gap-1.5">
        <% [["Su", 0], ["Mo", 1], ["Tu", 2], ["We", 3], ["Th", 4], ["Fr", 5], ["Sa", 6]].each do |lbl, wday| %>
          <label class="relative cursor-pointer">
            <%= f.check_box :repeat_days, { multiple: true, class: "peer sr-only" }, wday, nil %>
            <div class="repeat-day-btn flex h-9 items-center justify-center rounded-xl border text-xs font-semibold transition-all
                        border-zinc-700 bg-zinc-900/40 text-zinc-400
                        hover:border-zinc-500 hover:text-zinc-200">
              <%= lbl %>
            </div>
          </label>
        <% end %>
      </div>
    </div>
    <!-- Color card -->
    <div class="rounded-2xl p-4"
         style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg-2);">
      <div class="text-sm font-semibold text-zinc-200">Course color</div>
      <div class="text-xs text-zinc-500 mt-0.5 mb-4">Used as the calendar highlight</div>
      <div class="flex items-center gap-3">
        <%= f.color_field :color,
              class: "h-12 w-20 cursor-pointer rounded-xl border bg-zinc-950/40",
              style: "border-color: var(--studs-border);" %>
        <span class="text-xs text-zinc-500">Click to pick a color</span>
      </div>
    </div>
  </div>
  <!-- Submit -->
  <div class="flex items-center gap-3 pt-4"
       style="border-top: 1px solid var(--studs-divider);">
    <button type="submit" class="studs-btn-accent">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
      </svg>
      <%= (course.persisted? || draft_temp_course) ? "Update course" : "Create course" %>
    </button>
    <% if cancel_drawer %>
      <button type="button" class="studs-nav-btn" data-action="drawer#close">Cancel</button>
    <% else %>
      <%= link_to "Cancel", dashboard_path, class: "studs-nav-btn" %>
    <% end %>
  </div>
<% end %>
