<%= turbo_frame_tag "event_popover" do %>
  <% course_identifier = local_assigns[:course_identifier] || course %>
  <div class="w-[26rem]">
  <!-- Header -->
  <div class="flex items-center justify-between gap-3 px-4 pt-3 pb-2">
    <div class="flex items-center gap-2 min-w-0">
      <span class="h-3 w-3 shrink-0 rounded-full" style="background-color:<%= course.color.presence || '#34D399' %>"></span>
      <div class="text-sm font-semibold text-zinc-100 truncate">
        <%= course.title.presence || "Untitled Course" %>
      </div>
      <% if course.code.present? %>
        <span class="shrink-0 text-xs text-zinc-500"><%= course.code %></span>
      <% end %>
    </div>
    <button
      type="button"
      data-action="event-popover#close"
      class="shrink-0 inline-flex items-center justify-center h-6 w-6 rounded-lg text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800 transition text-xs">
      ✕
    </button>
  </div>
  <!-- Details -->
  <div class="px-4 pb-3 space-y-2 text-sm">
    <% if course.start_time.present? && course.end_time.present? %>
      <div class="flex items-center gap-2 text-zinc-300">
        <svg class="h-4 w-4 shrink-0 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <span><%= course.start_time.strftime("%-I:%M %p") %> – <%= course.end_time.strftime("%-I:%M %p") %></span>
      </div>
    <% end %>
    <% if course.professor.present? %>
      <div class="flex items-center gap-2 text-zinc-300">
        <svg class="h-4 w-4 shrink-0 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
        <span><%= course.professor %></span>
      </div>
    <% end %>
    <% if course.location.present? %>
      <div class="flex items-center gap-2 text-zinc-300">
        <svg class="h-4 w-4 shrink-0 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        <span><%= course.location %></span>
      </div>
    <% end %>
    <% if course.repeat_days.present? %>
      <div class="flex items-center gap-2 text-zinc-300">
        <svg class="h-4 w-4 shrink-0 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
        </svg>
        <% day_names = %w[Sun Mon Tue Wed Thu Fri Sat] %>
        <% days = Array(course.repeat_days).map { |d| day_names[d.to_i] }.join(", ") %>
        <span>
          <%= days %>
          <% end_date = course.repeat_until.presence || course.end_date %>
          <% if end_date.present? %>
            until <%= end_date.strftime("%b %-d, %Y") %>
          <% end %>
        </span>
      </div>
    <% end %>
    <% if course.term.present? %>
      <div class="flex items-center gap-2 text-zinc-300">
        <svg class="h-4 w-4 shrink-0 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        <span><%= course.term %></span>
      </div>
    <% end %>
    <% if @project.present? && course.user.present? %>
      <div class="flex items-center gap-2 text-zinc-300">
        <svg class="h-4 w-4 shrink-0 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
        <span>Created by <%= course.user.username.presence || course.user.email %></span>
      </div>
    <% end %>
  </div>
  <!-- Actions -->
  <div class="flex items-center gap-2 px-4 pb-3 pt-1 border-t border-zinc-800">
    <%= link_to edit_course_path(course_identifier, start_date: start_date),
          data: { turbo: false },
          class: "inline-flex items-center gap-1.5 rounded-lg px-3 py-1.5 text-sm text-zinc-200 hover:bg-zinc-800 transition" do %>
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
      </svg>
      Edit
    <% end %>
    <% if course.persisted? %>
      <%= link_to course_course_items_path(course),
            data: { turbo: false },
            class: "inline-flex items-center gap-1.5 rounded-lg px-3 py-1.5 text-sm text-zinc-200 hover:bg-zinc-800 transition" do %>
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
        Items
      <% end %>
    <% end %>
    <div data-controller="delete-options" class="relative">
      <button
          type="button"
          data-action="delete-options#toggle"
          class="inline-flex items-center gap-1.5 rounded-lg px-3 py-1.5 text-sm text-rose-300 hover:bg-rose-950/40 transition">
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
        Delete
        <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
        </svg>
      </button>
      <div
          data-delete-options-target="menu"
          class="hidden absolute bottom-full left-0 mb-1 w-52 rounded-lg border border-zinc-700 py-1 z-50"
          style="background-color: #18181b; box-shadow: 0 8px 30px rgba(0,0,0,0.7);">
        <%= button_to course_path(course_identifier, start_date: start_date, scope: "single"),
                method: :delete,
                class: "w-full text-left px-3 py-2 text-sm text-zinc-200 hover:bg-zinc-800 transition" do %>
          This course event only
        <% end %>
        <%= button_to course_path(course_identifier, start_date: start_date, scope: "all"),
                method: :delete,
                class: "w-full text-left px-3 py-2 text-sm text-rose-300 hover:bg-rose-950/40 transition",
                form: { data: { turbo_confirm: "Delete all occurrences of this course?" } } do %>
          All course events in series
        <% end %>
      </div>
    </div>
    <%= render "shared/change_type_dropdown", source_type: "course", record: course, start_date: start_date, variant: :popover if course.persisted? %>
  </div>
  </div>
<% end %>
