<%# Turbo-frame fallback: ensures the event_drawer frame is present in the response
    if the Turbo-Frame header is not detected. %>
<div hidden><%= render "courses/drawer_edit", course: @course, start_date: params[:start_date] %></div>
<% content_for :page_title, "Edit Course" %>
<% content_for :page_subtitle, @course.title.presence || "Update details" %>
<div class="rounded-2xl p-6"
     style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg);">
  <div class="mb-6 pb-4" style="border-bottom: 1px solid var(--studs-divider);">
    <div class="flex items-center justify-between">
      <div>
        <div class="text-base font-semibold text-zinc-100">Edit course</div>
        <div class="mt-0.5 text-sm text-zinc-500">Update the details below and save.</div>
      </div>
      <%= link_to dashboard_path, class: "studs-nav-btn" do %>
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        Back
      <% end %>
    </div>
  </div>
  <%= render "form", course: @course, turbo: false, course_identifier: @draft_temp_id %>
</div>
