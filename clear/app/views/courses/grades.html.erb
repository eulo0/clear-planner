<% content_for :page_title, (@course.title.presence || "Course") %>
<% content_for :page_subtitle, "Grades" %>
<% color = @course.color.presence || "#34D399" %>
<% overall = @course.overall_grade %>
<% graded_by_kind = @items_by_kind.transform_values { |items| items.select(&:graded?) } %>
<% active_weights = @course.grade_weights.select { |_, w| w.to_f > 0 } %>

<div class="rounded-2xl p-6 space-y-5" style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg);">
  <!-- Header -->
  <div class="flex items-center justify-between gap-4">
    <div class="min-w-0 flex-1">
      <div class="text-base font-semibold text-zinc-100 truncate"><%= @course.title.presence || "Course" %></div>
      <div class="text-sm text-zinc-400">Grade breakdown by assignment type.</div>
    </div>
    <div class="flex items-center gap-2 shrink-0">
      <%= link_to courses_path, class: "studs-nav-btn inline-flex items-center gap-2" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        Back to Courses
      <% end %>
      <%= link_to course_course_items_path(@course), class: "studs-nav-btn inline-flex items-center gap-2" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        Back to Items
      <% end %>
    </div>
  </div>

  <!-- Overall Grade Summary -->
  <details class="rounded-2xl" style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg-2);" open>
    <summary class="flex cursor-pointer list-none items-center gap-3 p-4 select-none">
      <svg class="toggle-chevron h-3.5 w-3.5 shrink-0 text-zinc-400 transition-transform" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
      </svg>
      <div class="text-[10px] font-bold uppercase tracking-widest" style="color: var(--studs-accent); opacity: 0.8;">Overall Grade</div>
      <div id="overall-grade-display" class="flex items-center gap-1">
        <% if overall %>
          <span id="overall-letter" class="text-xl font-bold" style="color: var(--studs-accent);"><%= @course.letter_grade(overall) %></span>
          <span id="overall-pct" class="text-sm text-zinc-300"><%= overall %>%</span>
        <% else %>
          <span id="overall-letter" class="text-xl font-bold" style="color: var(--studs-accent); display:none;"></span>
          <span id="overall-pct" class="text-sm text-zinc-500">—</span>
        <% end %>
      </div>
    </summary>
    <div class="px-4 pb-4">
      <!-- Weighted breakdown (shown when weighted mode is active) -->
      <div id="overall-weighted-view" class="<%= @course.grade_calculation == 'weighted' ? '' : 'hidden' %>">
        <% if active_weights.any? %>
          <div class="grid grid-cols-2 gap-1.5 sm:grid-cols-3 lg:grid-cols-4">
            <% active_weights.each do |kind, weight| %>
              <% items = graded_by_kind[kind] || [] %>
              <% avg = items.any? ? (items.sum { |i| i.points_earned.to_f / i.points_possible.to_f } / items.size * 100).round(1) : nil %>
              <div class="rounded-xl px-3 py-2 text-center" style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-hover);">
                <div class="text-[10px] font-semibold uppercase tracking-wide text-zinc-300"><%= kind.humanize %></div>
                <div class="text-xs text-zinc-400 mt-0.5"><%= sprintf("%g", weight.to_f.round(1)) %>% weight</div>
                <div class="text-sm font-semibold mt-1" style="color: var(--studs-accent);">
                  <%= avg ? "#{avg}%" : "—" %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-xs text-zinc-500">Set grade weights below, or switch to Points mode to calculate by raw points.</p>
        <% end %>
      </div>
      <!-- Points breakdown (shown when points mode is active) -->
      <% graded_items = @course.course_items.select(&:graded?) %>
      <% total_earned   = graded_items.sum { |i| i.points_earned.to_f } %>
      <% total_possible = graded_items.sum { |i| i.points_possible.to_f } %>
      <div id="overall-points-view" class="<%= @course.grade_calculation == 'weighted' ? 'hidden' : '' %>">
        <% if graded_items.any? %>
          <div class="flex flex-wrap items-center gap-6 text-sm">
            <div>
              <span class="text-zinc-400">Points earned:</span>
              <span class="font-semibold text-zinc-100 ml-1"><%= sprintf("%g", total_earned.round(1)) %></span>
            </div>
            <div>
              <span class="text-zinc-400">Points possible:</span>
              <span class="font-semibold text-zinc-100 ml-1"><%= sprintf("%g", total_possible.round(1)) %></span>
            </div>
            <div>
              <span class="text-zinc-400">Items graded:</span>
              <span class="font-semibold text-zinc-100 ml-1"><%= graded_items.size %></span>
            </div>
          </div>
        <% else %>
          <p class="text-xs text-zinc-500">No graded items yet. Add points to items to track your grade.</p>
        <% end %>
      </div>
    </div>
  </details>

  <!-- Calculation Method -->
  <details class="rounded-2xl" style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg-2);" open>
    <summary class="flex cursor-pointer list-none items-center gap-3 p-4 select-none">
      <svg class="toggle-chevron h-3.5 w-3.5 shrink-0 text-zinc-400 transition-transform" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
      </svg>
      <div class="text-[10px] font-bold uppercase tracking-widest" style="color: var(--studs-accent); opacity: 0.8;">Calculation Method</div>
      <span class="text-xs text-zinc-400"><%= @course.grade_calculation.humanize %></span>
    </summary>
    <div class="px-4 pb-4">
      <%= form_with url: update_grade_calculation_course_path(@course), method: :patch, class: "space-y-3", id: "grade-calc-form" do %>
        <div class="space-y-2">
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="radio" name="grade_calculation" value="points"
                   <%= "checked" if @course.grade_calculation == "points" %>
                   class="mt-0.5">
            <div>
              <div class="text-sm font-medium text-zinc-100">Points</div>
              <div class="text-xs text-zinc-400">Total points earned ÷ total points possible across all graded items.</div>
            </div>
          </label>
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="radio" name="grade_calculation" value="weighted"
                   <%= "checked" if @course.grade_calculation == "weighted" %>
                   class="mt-0.5">
            <div>
              <div class="text-sm font-medium text-zinc-100">Weighted</div>
              <div class="text-xs text-zinc-400">Category averages multiplied by their weights. Falls back to points if no weights are set.</div>
            </div>
          </label>
        </div>
      <% end %>
    </div>
  </details>

  <!-- Grade Weights -->
  <details id="grade-weights-section" class="rounded-2xl <%= @course.grade_calculation == 'points' ? 'hidden' : '' %>" style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg-2);" open>
    <summary class="flex cursor-pointer list-none items-center justify-between p-4 select-none">
      <div class="flex items-center gap-2">
        <svg class="toggle-chevron h-3.5 w-3.5 shrink-0 text-zinc-400 transition-transform" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
        </svg>
        <div class="text-[10px] font-bold uppercase tracking-widest" style="color: var(--studs-accent); opacity: 0.8;">Grade Weights (%)</div>
      </div>
      <div class="text-xs font-semibold text-zinc-400">
        Total: <span id="weights-total-value"><%= @course.grade_weights.values.sum(&:to_f).round(1) %></span>%
      </div>
    </summary>
    <div class="px-4 pb-4">
    <div id="weights-over-warning" class="hidden rounded-xl px-3 py-2 mb-3 text-sm font-medium"
         style="background-color: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #fca5a5;">
      Weights exceed 100%. Please reduce before saving.
    </div>
    <div id="weights-negative-warning" class="hidden rounded-xl px-3 py-2 mb-3 text-sm font-medium"
         style="background-color: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #fca5a5;">
      Weights cannot be negative. Please enter 0 or above.
    </div>
    <div id="weights-invalid-warning" class="hidden rounded-xl px-3 py-2 mb-3 text-sm font-medium"
         style="background-color: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #fca5a5;">
      One or more weights contain an invalid value. Please enter numbers only.
    </div>
    <%= form_with url: update_grade_weights_course_path(@course), method: :patch, class: "space-y-3", id: "grade-weights-form" do %>
      <div id="weight-rows" class="space-y-2">
        <% CourseItem.kinds.keys.each do |kind| %>
          <% weight = @course.grade_weights[kind] %>
          <% next unless weight.to_f > 0 %>
          <div class="weight-row flex items-center gap-3" data-kind="<%= kind %>">
            <span class="text-sm text-zinc-300 w-28 shrink-0"><%= kind.humanize %></span>
            <input type="number" name="grade_weights[<%= kind %>]"
                   value="<%= weight %>"
                   min="0" max="100" step="any" placeholder="0"
                   class="grade-weight-input flex-1 rounded-2xl px-3 py-2 text-sm text-zinc-100 placeholder:text-zinc-600 bg-zinc-950/60 focus:outline-none focus:ring-2 transition-all duration-150 border"
                   style="border-color: var(--studs-border); --tw-ring-color: var(--studs-accent);">
            <button type="button"
                    class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-lg border text-zinc-400 hover:text-rose-300 hover:border-rose-500/40 hover:bg-rose-950/30 transition"
                    style="border-color: var(--studs-border);"
                    onclick="removeWeightRow(this, '<%= kind %>')">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
        <% end %>
      </div>

      <p id="no-weights-msg" class="text-xs text-zinc-500 <%= @course.grade_weights.values.any? { |w| w.to_f > 0 } ? 'hidden' : '' %>">
        No categories added yet. Use the dropdown below to add one.
      </p>

      <div class="flex items-center gap-2">
        <select id="kind-select"
                class="flex-1 rounded-2xl px-3 py-2 text-sm text-zinc-100 bg-zinc-950/60 focus:outline-none transition-all duration-150 border"
                style="border-color: var(--studs-border); --tw-ring-color: var(--studs-accent);">
          <option value="">— Add a category —</option>
          <% CourseItem.kinds.keys.each do |kind| %>
            <% next if @course.grade_weights[kind].to_f > 0 %>
            <option value="<%= kind %>"><%= kind.humanize %></option>
          <% end %>
        </select>
        <button type="button" onclick="addWeightRow()" class="studs-nav-btn shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
          </svg>
          Add
        </button>
      </div>

    <% end %>
    </div>
  </details>

  <!-- Save Changes -->
  <div class="flex justify-end">
    <button id="save-changes-btn" type="button" class="studs-btn-accent">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
      </svg>
      Save changes
    </button>
  </div>

  <!-- What-If banner -->
  <div id="whatif-banner" class="hidden rounded-2xl px-4 py-3 flex items-center justify-between gap-4"
       style="background-color: rgba(251,191,36,0.08); border: 1px solid rgba(251,191,36,0.3);">
    <div class="flex items-center gap-2 text-sm font-medium" style="color: #fbbf24;">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
      </svg>
      What-If grades — scores are hypothetical and not saved.
    </div>
    <button onclick="resetWhatIf()" class="text-xs font-semibold hover:underline shrink-0" style="color: #fbbf24;">
      Reset to actual
    </button>
  </div>

  <!-- Items table -->
  <div id="items-table"
       class="overflow-hidden rounded-2xl"
       style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg-2);"
       data-grade-calculation="<%= @course.grade_calculation %>"
       data-grade-weights="<%= @course.grade_weights.to_json %>"
       data-grading-scale="<%= Course::GRADING_SCALE.to_json %>">
    <% if @items_by_kind.any? %>
      <% @items_by_kind.each do |kind, items| %>
        <div class="px-5 py-2 text-[10px] font-bold uppercase tracking-widest"
             style="background-color: var(--studs-panel-hover); border-bottom: 1px solid var(--studs-divider); color: var(--studs-accent); opacity: 0.9;">
          <%= kind.humanize %>
        </div>
        <% items.each do |item| %>
          <% has_possible = item.points_possible.present? && item.points_possible > 0 %>
          <div class="whatif-row grid grid-cols-12 items-center gap-4 px-5 py-3"
               data-kind="<%= item.kind %>"
               style="border-left: 3px solid <%= color %>; border-bottom: 1px solid var(--studs-divider);">
            <div class="col-span-6">
              <p class="text-sm font-medium text-zinc-100"><%= item.title.presence || "(Untitled)" %></p>
              <% if item.due_at.present? %>
                <p class="text-xs text-zinc-400 mt-0.5"><%= item.due_at.strftime("%b %-d at %-I:%M%P") %></p>
              <% end %>
            </div>

            <div class="col-span-4 text-sm text-zinc-300">
              <% if has_possible %>
                <div class="flex items-center gap-1.5">
                  <input type="number"
                         class="whatif-input w-20 rounded-lg px-2 py-0.5 text-sm font-semibold text-zinc-100 bg-zinc-950/60 border focus:outline-none focus:ring-1 transition-colors"
                         style="border-color: var(--studs-border); --tw-ring-color: var(--studs-accent);"
                         value="<%= item.points_earned %>"
                         placeholder="—"
                         data-actual="<%= item.points_earned.to_s %>"
                         data-possible="<%= item.points_possible %>"
                         min="0" step="any">
                  <span class="text-zinc-400 text-xs">/ <%= item.points_possible %></span>
                </div>
              <% else %>
                <span class="text-zinc-400">—</span>
              <% end %>
            </div>

            <div class="col-span-2 text-right">
              <% if has_possible %>
                <% actual_pct = item.graded? ? "#{item.grade_percentage}%" : "" %>
                <span class="whatif-pct text-sm font-semibold"
                      style="<%= item.graded? ? "color: var(--studs-accent);" : "color: var(--studs-text-muted, #71717a);" %>"
                      data-actual-display="<%= actual_pct %>">
                  <%= actual_pct.presence || "—" %>
                </span>
              <% else %>
                <span class="text-xs text-zinc-400">Not graded</span>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>

      <!-- Total row -->
      <div class="grid grid-cols-12 items-center gap-4 px-5 py-4">
        <div class="col-span-6 text-base font-bold text-zinc-100">Total</div>
        <div class="col-span-4"></div>
        <div class="col-span-2 text-right text-base font-bold" id="whatif-total" style="color: var(--studs-accent);">
          <% if overall %>
            <%= @course.letter_grade(overall) %> &nbsp; <%= overall %>%
          <% else %>
            <span class="text-zinc-400 text-sm font-normal">No grades yet</span>
          <% end %>
        </div>
      </div>

    <% else %>
      <div class="flex flex-col items-center justify-center py-16 text-center">
        <p class="text-sm font-medium text-zinc-300">No items yet</p>
        <p class="mt-1 text-xs text-zinc-400">Add course items to start tracking grades</p>
      </div>
    <% end %>
  </div>
</div>

<style>
  details[open] > summary .toggle-chevron { transform: rotate(0deg); }
  details:not([open]) > summary .toggle-chevron { transform: rotate(-90deg); }
  .grade-weight-input::-webkit-inner-spin-button,
  .grade-weight-input::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
  .grade-weight-input { -moz-appearance: textfield; }
  input[type=number]::-webkit-inner-spin-button,
  input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
  input[type=number] { -moz-appearance: textfield; }
</style>

<script>
  const ALL_KINDS = <%= CourseItem.kinds.keys.map { |k| [k, k.humanize] }.to_json.html_safe %>;

// ── Grade weight helpers (called by inline onclick, must be global) ──────────
  function updateTotal() {
    const totalEl = document.getElementById("weights-total-value");
    if (!totalEl) return; // not on grades page
    const inputs  = Array.from(document.querySelectorAll(".grade-weight-input"));
    const badInput = inputs.some(el => el.validity.badInput);
    const values  = inputs.map(el => parseFloat(el.value) || 0);
    const total   = values.reduce((sum, v) => sum + v, 0);
    totalEl.textContent = Math.round(total * 10) / 10;
    const over     = total > 100.001;
    const negative = values.some(v => v < 0);
    const invalid  = over || negative || badInput;
    document.getElementById("weights-over-warning").classList.toggle("hidden", !over);
    document.getElementById("weights-negative-warning").classList.toggle("hidden", !negative);
    document.getElementById("weights-invalid-warning").classList.toggle("hidden", !badInput);
    const submitBtn = document.getElementById("save-changes-btn");
    if (submitBtn) {
      submitBtn.disabled = invalid;
      submitBtn.style.opacity = invalid ? "0.4" : "";
      submitBtn.style.cursor = invalid ? "not-allowed" : "";
    }
  }

  function activeKinds() {
    return Array.from(document.querySelectorAll("#weight-rows .weight-row")).map(r => r.dataset.kind);
  }

  function refreshDropdown() {
    const active = activeKinds();
    const select = document.getElementById("kind-select");
    const prev = select.value;
    select.innerHTML = '<option value="">— Add a category —</option>';
    ALL_KINDS.forEach(([kind, label]) => {
      if (!active.includes(kind)) {
        const opt = document.createElement("option");
        opt.value = kind;
        opt.textContent = label;
        if (kind === prev) opt.selected = true;
        select.appendChild(opt);
      }
    });
  }

  function refreshEmptyMsg() {
    const hasRows = document.querySelectorAll("#weight-rows .weight-row").length > 0;
    document.getElementById("no-weights-msg").classList.toggle("hidden", hasRows);
  }

  function addWeightRow() {
    const select = document.getElementById("kind-select");
    const kind = select.value;
    if (!kind) return;
    const label = select.options[select.selectedIndex].textContent;

    const row = document.createElement("div");
    row.className = "weight-row flex items-center gap-3";
    row.dataset.kind = kind;
    row.innerHTML = `
      <span class="text-sm text-zinc-300 w-28 shrink-0">${label}</span>
      <input type="number" name="grade_weights[${kind}]"
             min="0" max="100" step="any" placeholder="0"
             class="grade-weight-input flex-1 rounded-2xl px-3 py-2 text-sm text-zinc-100 placeholder:text-zinc-600 bg-zinc-950/60 focus:outline-none focus:ring-2 transition-all duration-150 border"
             style="border-color: var(--studs-border); --tw-ring-color: var(--studs-accent);">
      <button type="button"
              class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-lg border text-zinc-400 hover:text-rose-300 hover:border-rose-500/40 hover:bg-rose-950/30 transition"
              style="border-color: var(--studs-border);"
              onclick="removeWeightRow(this, '${kind}')">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    `;

    document.getElementById("weight-rows").appendChild(row);
    row.querySelector(".grade-weight-input").addEventListener("input", updateTotal);
    row.querySelector(".grade-weight-input").focus();

    refreshDropdown();
    refreshEmptyMsg();
    updateTotal();
  }

  function removeWeightRow(btn, kind) {
    btn.closest(".weight-row").remove();
    refreshDropdown();
    refreshEmptyMsg();
    updateTotal();
  }

  function showAppToast(msg) {
    const container = document.getElementById("toast-container");
    if (!container) return;
    const el = document.createElement("div");
    el.setAttribute("data-controller", "toast");
    el.setAttribute("data-toast-duration-value", "4000");
    el.className = "relative pointer-events-auto flex items-start gap-3 rounded-xl border px-4 py-3 text-sm text-zinc-100 overflow-hidden backdrop-blur-md shadow-lg translate-x-full opacity-0 transition-all duration-300 ease-out min-w-[280px] max-w-[400px]";
    el.style.borderColor = "var(--studs-border)";
    el.style.backgroundColor = "color-mix(in srgb, var(--studs-sidebar-bg) 85%, transparent)";
    el.innerHTML =
      `<svg class="h-5 w-5 shrink-0 mt-0.5" style="color: var(--studs-accent);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>` +
      `<span class="flex-1">${msg}</span>` +
      `<button type="button" data-action="toast#dismiss" class="shrink-0 text-zinc-500 hover:text-zinc-200 transition-colors text-lg leading-none">&times;</button>` +
      `<div class="absolute bottom-0 left-0 h-0.5 rounded-full" style="background-color: var(--studs-accent); width: 100%;" data-toast-progress></div>`;
    container.appendChild(el);
  }

  // Block accidental form submissions immediately (before turbo:load fires).
  // Pressing Enter in a weight input would otherwise submit via Turbo.
  document.getElementById("grade-calc-form")   ?.addEventListener("submit", e => e.preventDefault());
  document.getElementById("grade-weights-form") ?.addEventListener("submit", e => e.preventDefault());

  // ── Page initialization ──────────────────────────────────────────────────────
  // Wrapped in turbo:load so it re-runs on every Turbo navigation — including
  // browser back-button restores where Turbo shows a cached page WITHOUT
  // re-executing inline scripts. Storing on window and removing before re-adding
  // prevents accumulation when the script does re-execute (application visits).
  if (window._gradesPageHandler) {
    document.removeEventListener("turbo:load", window._gradesPageHandler);
  }

  window._gradesPageHandler = function () {
    // Re-attach grade weight input listeners (lost on cache restore)
    document.querySelectorAll(".grade-weight-input").forEach(el => {
      el.addEventListener("input", updateTotal);
    });
    updateTotal();

    // ── What-If grades ────────────────────────────────────────────────────────
    const table = document.getElementById("items-table");
    if (!table) return;

    const WHATIF_SCALE = JSON.parse(table.dataset.gradingScale || '{"A":90,"B":80,"C":70,"D":60}');

    function letterGradeWhatIf(pct) {
      const entries = Object.entries(WHATIF_SCALE).sort((a, b) => b[1] - a[1]);
      for (const [letter, threshold] of entries) {
        if (pct >= threshold) return letter;
      }
      return "F";
    }

    function recalculate(skipBanner) {
      const WHATIF_CALC    = table.dataset.gradeCalculation || "points";
      const WHATIF_WEIGHTS = JSON.parse(table.dataset.gradeWeights || "{}");

      const rows   = Array.from(document.querySelectorAll(".whatif-row"));
      const inputs = rows.map(r => r.querySelector(".whatif-input")).filter(Boolean);

      rows.forEach(row => {
        const input   = row.querySelector(".whatif-input");
        const pctSpan = row.querySelector(".whatif-pct");
        if (!input || !pctSpan) return;

        const val      = input.value.trim();
        const possible = parseFloat(input.dataset.possible) || 0;

        if (val !== "" && !isNaN(parseFloat(val)) && possible > 0) {
          const pct = Math.round(parseFloat(val) / possible * 1000) / 10;
          pctSpan.textContent = pct + "%";
          pctSpan.style.color = "var(--studs-accent)";
        } else {
          pctSpan.textContent = "—";
          pctSpan.style.color = "var(--studs-text-muted, #71717a)";
        }
      });

      const hasChanges = inputs.some(i => {
        const actual  = i.dataset.actual || "";
        const current = i.value.trim();
        if (actual === "" && current === "") return false;
        if (actual === "" || current === "") return true;
        return parseFloat(current) !== parseFloat(actual);
      });
      if (!skipBanner) document.getElementById("whatif-banner").classList.toggle("hidden", !hasChanges);

      const graded = inputs.filter(i => {
        const v = i.value.trim();
        return v !== "" && !isNaN(parseFloat(v)) && parseFloat(i.dataset.possible || 0) > 0;
      });

      let grade = null;
      const weightsSum  = Object.values(WHATIF_WEIGHTS).reduce((s, w) => s + parseFloat(w || 0), 0);
      const useWeighted = WHATIF_CALC === "weighted" && weightsSum > 0;

      if (graded.length > 0) {
        if (useWeighted) {
          let weightedSum = 0, totalWeight = 0;

          for (const [kind, weight] of Object.entries(WHATIF_WEIGHTS)) {
            const w = parseFloat(weight || 0);
            if (w <= 0) continue;
            const kindItems = graded.filter(i => i.closest(".whatif-row")?.dataset.kind === kind);
            if (kindItems.length === 0) continue;

            const avg = kindItems.reduce((s, i) =>
              s + parseFloat(i.value) / parseFloat(i.dataset.possible), 0
            ) / kindItems.length;

            weightedSum += w * avg;
            totalWeight += w;
          }

          if (totalWeight > 0) grade = Math.round(weightedSum / totalWeight * 1000) / 10;
        } else {
          const earned   = graded.reduce((s, i) => s + parseFloat(i.value), 0);
          const possible = graded.reduce((s, i) => s + parseFloat(i.dataset.possible), 0);
          if (possible > 0) grade = Math.round(earned / possible * 1000) / 10;
        }
      }

      const totalEl  = document.getElementById("whatif-total");
      const letterEl = document.getElementById("overall-letter");
      const pctEl    = document.getElementById("overall-pct");

      if (grade !== null) {
        const letter = letterGradeWhatIf(grade);
        if (totalEl)  { totalEl.innerHTML = `${letter}&nbsp;&nbsp;${grade}%`; totalEl.style.color = "var(--studs-accent)"; }
        if (letterEl) { letterEl.textContent = letter; letterEl.style.display = ""; }
        if (pctEl)    { pctEl.textContent = grade + "%"; pctEl.style.color = ""; }
      } else {
        if (totalEl)  { totalEl.innerHTML = '<span class="text-zinc-400 text-sm font-normal">No grades yet</span>'; }
        if (letterEl) { letterEl.textContent = ""; letterEl.style.display = "none"; }
        if (pctEl)    { pctEl.textContent = "—"; }
      }
    }

    function resetWhatIf() {
      document.querySelectorAll(".whatif-input").forEach(input => {
        input.value = input.dataset.actual || "";
        const pctSpan = input.closest(".whatif-row")?.querySelector(".whatif-pct");
        if (pctSpan) {
          const actualDisplay = pctSpan.dataset.actualDisplay;
          pctSpan.textContent = actualDisplay || "—";
          pctSpan.style.color = actualDisplay ? "var(--studs-accent)" : "var(--studs-text-muted, #71717a)";
        }
      });
      recalculate();
    }

    // Sync section visibility with current radio on every init (covers Turbo restores)
    const weightsSection = document.getElementById("grade-weights-section");
    const checkedRadio = document.querySelector('input[name="grade_calculation"]:checked');
    if (checkedRadio) {
      const isWeighted = checkedRadio.value === "weighted";
      if (weightsSection) weightsSection.classList.toggle("hidden", !isWeighted);
      document.getElementById("overall-weighted-view")?.classList.toggle("hidden", !isWeighted);
      document.getElementById("overall-points-view")?.classList.toggle("hidden", isWeighted);
    }

    document.querySelectorAll('input[name="grade_calculation"]').forEach(radio => {
      radio.addEventListener("change", () => {
        table.dataset.gradeCalculation = radio.value;
        const isWeighted = radio.value === "weighted";
        const ws = document.getElementById("grade-weights-section");
        if (ws) ws.classList.toggle("hidden", !isWeighted);
        document.getElementById("overall-weighted-view")?.classList.toggle("hidden", !isWeighted);
        document.getElementById("overall-points-view")?.classList.toggle("hidden", isWeighted);
        recalculate(true); // skip banner — mode switch shouldn't trigger what-if
      });
    });

    // Event delegation on the stable table container
    table.addEventListener("input", function (e) {
      if (e.target.classList.contains("whatif-input")) recalculate();
    });

    // Prevent both forms from navigating (also done at parse time, but
    // turbo:load re-attaches after cache restores which strip listeners).
    const calcForm    = document.getElementById("grade-calc-form");
    const weightsForm = document.getElementById("grade-weights-form");
    if (calcForm)    calcForm.addEventListener("submit",    e => e.preventDefault());
    if (weightsForm) weightsForm.addEventListener("submit", e => e.preventDefault());

    function weightsSnapshot() {
      const w = {};
      document.querySelectorAll("#weight-rows .weight-row").forEach(row => {
        const input = row.querySelector(".grade-weight-input");
        if (input) w[row.dataset.kind] = parseFloat(input.value) || 0;
      });
      return JSON.stringify(w);
    }

    let baseCalc    = document.querySelector('input[name="grade_calculation"]:checked')?.value || "";
    let baseWeights = weightsSnapshot();

    // Unified Save Changes button.
    // .onclick assignment prevents listener accumulation across turbo:load calls.
    const saveBtn = document.getElementById("save-changes-btn");
    if (saveBtn) {
      saveBtn.onclick = function () {
        const csrfToken      = document.querySelector('meta[name="csrf-token"]')?.content || "";
        const nowCalc        = document.querySelector('input[name="grade_calculation"]:checked')?.value || "";
        const nowWeights     = weightsSnapshot();
        const calcChanged    = nowCalc !== baseCalc;
        const weightsChanged = nowWeights !== baseWeights;

        if (!calcChanged && !weightsChanged) return;

        const saves = [];

        if (calcForm && calcChanged) {
          saves.push(fetch(calcForm.action, {
            method: "PATCH",
            headers: { "X-CSRF-Token": csrfToken, "Content-Type": "application/x-www-form-urlencoded" },
            body: "grade_calculation=" + encodeURIComponent(nowCalc)
          }));
        }

        if (weightsForm && weightsChanged) {
          const params = new URLSearchParams();
          document.querySelectorAll("#weight-rows .weight-row").forEach(row => {
            const input = row.querySelector(".grade-weight-input");
            if (input) params.append("grade_weights[" + row.dataset.kind + "]", input.value || "0");
          });
          saves.push(fetch(weightsForm.action, {
            method: "PATCH",
            headers: { "X-CSRF-Token": csrfToken, "Content-Type": "application/x-www-form-urlencoded" },
            body: params.toString()
          }));
        }

        Promise.all(saves).then(() => {
          baseCalc    = nowCalc;
          baseWeights = nowWeights;
          const msg = calcChanged && weightsChanged ? "Changes saved."
                    : calcChanged                   ? "Grade calculation updated."
                                                    : "Grade weights updated.";
          showAppToast(msg);
        }).catch(err => console.error("Save failed:", err));
      };
    }

    window.resetWhatIf = resetWhatIf;
  };

  document.addEventListener("turbo:load", window._gradesPageHandler);
</script>
