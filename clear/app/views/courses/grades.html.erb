<% content_for :page_title, (@course.title.presence || "Course") %>
<% content_for :page_subtitle, "Grades" %>
<% color = @course.color.presence || "#34D399" %>
<% overall = @course.overall_grade %>
<% graded_by_kind = @items_by_kind.transform_values { |items| items.select(&:graded?) } %>
<% active_weights = @course.grade_weights.select { |_, w| w.to_f > 0 } %>

<div class="rounded-2xl p-6 space-y-5" style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg);">
  <!-- Header -->
  <div class="flex items-center justify-between gap-4">
    <div class="min-w-0 flex-1">
      <div class="text-base font-semibold text-zinc-100 truncate"><%= @course.title.presence || "Course" %></div>
      <div class="text-sm text-zinc-500">Grade breakdown by assignment type.</div>
    </div>
    <%= link_to course_course_items_path(@course), class: "studs-nav-btn shrink-0" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      Back to items
    <% end %>
  </div>

  <!-- Overall Grade Summary -->
  <div class="rounded-2xl p-4 space-y-3" style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg-2);">
    <div class="flex items-center gap-3">
      <div class="text-[10px] font-bold uppercase tracking-widest" style="color: var(--studs-accent); opacity: 0.8;">Overall Grade</div>
      <% if overall %>
        <div class="flex items-center gap-1">
          <span class="text-xl font-bold" style="color: var(--studs-accent);"><%= @course.letter_grade(overall) %></span>
          <span class="text-sm text-zinc-400"><%= overall %>%</span>
        </div>
      <% else %>
        <span class="text-sm text-zinc-500">—</span>
      <% end %>
    </div>
    <% if active_weights.any? %>
      <div class="grid grid-cols-2 gap-1.5 sm:grid-cols-3 lg:grid-cols-4">
        <% active_weights.each do |kind, weight| %>
          <% items = graded_by_kind[kind] || [] %>
          <% avg = items.any? ? (items.sum { |i| i.grade_percentage } / items.size).round(1) : nil %>
          <div class="rounded-xl px-3 py-2 text-center" style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-hover);">
            <div class="text-[10px] font-semibold uppercase tracking-wide text-zinc-400"><%= kind.humanize %></div>
            <div class="text-xs text-zinc-500 mt-0.5"><%= weight.to_i %>% weight</div>
            <div class="text-sm font-semibold mt-1" style="color: var(--studs-accent);">
              <%= avg ? "#{avg}%" : "—" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-xs text-zinc-500">Set grade weights below to track your overall grade.</p>
    <% end %>
  </div>

  <!-- Grade Weights -->
  <div class="rounded-2xl p-4" style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg-2);">
    <div class="flex items-center justify-between mb-3">
      <div class="text-[10px] font-bold uppercase tracking-widest" style="color: var(--studs-accent); opacity: 0.8;">Grade Weights (%)</div>
      <div class="text-xs font-semibold text-zinc-400">
        Total: <span id="weights-total-value"><%= @course.grade_weights.values.sum(&:to_f).round(1) %></span>%
      </div>
    </div>
    <div id="weights-over-warning" class="hidden rounded-xl px-3 py-2 mb-3 text-sm font-medium"
         style="background-color: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #fca5a5;">
      Weights exceed 100%. Please reduce before saving.
    </div>
    <%= form_with url: update_grade_weights_course_path(@course), method: :patch, class: "space-y-3" do %>
      <div class="grid gap-3 grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5">
        <% CourseItem.kinds.keys.each do |kind| %>
          <div>
            <label class="block text-[10px] font-bold uppercase tracking-widest mb-1" style="color: var(--studs-accent); opacity: 0.8;"><%= kind.humanize %></label>
            <input type="number" name="grade_weights[<%= kind %>]"
                   value="<%= @course.grade_weights[kind].presence %>"
                   min="0" max="100" step="any"
                   placeholder="0"
                   class="grade-weight-input w-full rounded-2xl px-3 py-2 text-sm text-zinc-100 placeholder:text-zinc-600 bg-zinc-950/60 focus:outline-none focus:ring-2 transition-all duration-150 border"
                   style="border-color: var(--studs-border); --tw-ring-color: var(--studs-accent);">
          </div>
        <% end %>
      </div>
      <div class="pt-2" style="border-top: 1px solid var(--studs-divider);">
        <button type="submit" id="weights-submit-btn" class="studs-btn-accent">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
          </svg>
          Save weights
        </button>
      </div>
    <% end %>
  </div>

  <!-- Items table -->
  <div class="overflow-hidden rounded-2xl" style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg-2);">
    <% if @items_by_kind.any? %>
      <% @items_by_kind.each do |kind, items| %>
        <div class="px-5 py-2 text-[10px] font-bold uppercase tracking-widest"
             style="background-color: var(--studs-panel-hover); border-bottom: 1px solid var(--studs-divider); color: var(--studs-accent); opacity: 0.9;">
          <%= kind.humanize %>
        </div>
        <% items.each do |item| %>
          <div class="grid grid-cols-12 items-center gap-4 px-5 py-3"
               style="border-left: 3px solid <%= color %>; border-bottom: 1px solid var(--studs-divider);">
            <div class="col-span-6">
              <p class="text-sm font-medium text-zinc-100"><%= item.title.presence || "(Untitled)" %></p>
              <% if item.due_at.present? %>
                <p class="text-xs text-zinc-500 mt-0.5"><%= item.due_at.strftime("%b %-d at %-I:%M%P") %></p>
              <% end %>
            </div>
            <div class="col-span-4 text-sm text-zinc-300">
              <% if item.graded? %>
                <span class="font-semibold text-zinc-100"><%= item.points_earned %></span>
                <span class="text-zinc-500"> / <%= item.points_possible %></span>
              <% else %>
                <span class="text-zinc-600">—</span>
              <% end %>
            </div>
            <div class="col-span-2 text-right">
              <% if item.graded? %>
                <span class="text-sm font-semibold" style="color: var(--studs-accent);"><%= item.grade_percentage %>%</span>
              <% else %>
                <span class="text-xs text-zinc-600">Not graded</span>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>

      <!-- Category summary -->
      <% if active_weights.any? %>
        <div class="px-5 py-2 text-[10px] font-bold uppercase tracking-widest"
             style="background-color: var(--studs-panel-hover); border-bottom: 1px solid var(--studs-divider); border-top: 1px solid var(--studs-border); color: var(--studs-accent); opacity: 0.9;">
          Category Totals
        </div>
        <% active_weights.each do |kind, weight| %>
          <% items = graded_by_kind[kind] || [] %>
          <% earned = items.sum { |i| i.points_earned.to_f } %>
          <% possible = items.sum { |i| i.points_possible.to_f } %>
          <% avg = items.any? ? (items.sum { |i| i.grade_percentage } / items.size).round(1) : nil %>
          <div class="grid grid-cols-12 items-center gap-4 px-5 py-3"
               style="border-bottom: 1px solid var(--studs-divider);">
            <div class="col-span-6 text-sm font-medium text-zinc-300">
              <%= kind.humanize %>
              <span class="ml-2 text-xs text-zinc-600"><%= weight.to_i %>% weight</span>
            </div>
            <div class="col-span-4 text-sm text-zinc-400">
              <% if possible > 0 %>
                <%= earned.to_s.sub(/\.0$/, '') %> / <%= possible.to_s.sub(/\.0$/, '') %>
              <% else %>
                <span class="text-zinc-600">0.00 / 0.00</span>
              <% end %>
            </div>
            <div class="col-span-2 text-right text-sm font-semibold" style="color: var(--studs-accent);">
              <%= avg ? "#{avg}%" : "N/A" %>
            </div>
          </div>
        <% end %>
      <% end %>

      <!-- Total row -->
      <div class="grid grid-cols-12 items-center gap-4 px-5 py-4">
        <div class="col-span-6 text-base font-bold text-zinc-100">Total</div>
        <div class="col-span-4"></div>
        <div class="col-span-2 text-right text-base font-bold" style="color: var(--studs-accent);">
          <% if overall %>
            <%= @course.letter_grade(overall) %> &nbsp; <%= overall %>%
          <% else %>
            <span class="text-zinc-500 text-sm font-normal">No grades yet</span>
          <% end %>
        </div>
      </div>

    <% else %>
      <div class="flex flex-col items-center justify-center py-16 text-center">
        <p class="text-sm font-medium text-zinc-300">No items yet</p>
        <p class="mt-1 text-xs text-zinc-500">Add course items to start tracking grades</p>
      </div>
    <% end %>
  </div>
</div>

<script>
  (function () {
    const inputs = document.querySelectorAll(".grade-weight-input");
    const totalEl = document.getElementById("weights-total-value");
    const warning = document.getElementById("weights-over-warning");
    const submitBtn = document.getElementById("weights-submit-btn");

    function update() {
      const total = Array.from(inputs).reduce((sum, el) => sum + (parseFloat(el.value) || 0), 0);
      totalEl.textContent = Math.round(total * 10) / 10;
      const over = total > 100.001;
      warning.classList.toggle("hidden", !over);
      submitBtn.disabled = over;
      submitBtn.style.opacity = over ? "0.4" : "";
      submitBtn.style.cursor = over ? "not-allowed" : "";
    }

    inputs.forEach(el => el.addEventListener("input", update));
    update();
  })();
</script>
