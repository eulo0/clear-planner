<% content_for :page_title, "Courses" %>
<% content_for :page_subtitle, "Current enrolled courses" %>
<style>
  .course-row { transition: background-color 0.15s ease; }
  .course-row:hover { background-color: var(--studs-panel-hover); }
</style>
<div class="rounded-2xl p-6" style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg);">
  <!-- Header with search -->
  <%= form_with url: courses_path,
                method: :get,
                data: {
                  turbo_frame: "courses_list",
                  controller: "search",
                  search_target: "form"
                } do |f| %>
    <div class="flex items-center justify-between gap-4 mb-5">
      <div class="text-lg font-semibold text-zinc-100">Courses</div>
      <div class="flex items-center gap-1.5">
        <%= render Studs::SearchBarComponent.new(
              class_name: "w-72",
              placeholder: "Search courses…",
              value: params[:q],
              data: {
                search_target: "input",
                action: "input->search#search keydown->search#submit"
              }
            ) %>
        <div class="mx-1 h-5 w-px rounded-full" style="background-color: var(--studs-border);"></div>
        <%= link_to destroy_all_courses_path,
              class: "studs-nav-btn",
              style: "border-color: rgba(239,68,68,0.4); color: #fca5a5;",
              data: { turbo_method: :delete, turbo_confirm: "Delete all courses? This cannot be undone." } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
          Delete all
        <% end %>
        <div class="mx-1 h-5 w-px rounded-full" style="background-color: var(--studs-border);"></div>
        <%= link_to new_syllabus_path, class: "studs-nav-btn", data: { turbo_frame: "_top" } do %>
          <span class="[&>svg]:h-3.5 [&>svg]:w-3.5 [&>svg]:text-current [&>svg_*]:stroke-current">
            <%= icon "file-01-stroke-rounded" %>
          </span>
          Import from Syllabus
        <% end %>
        <div class="mx-1 h-5 w-px rounded-full" style="background-color: var(--studs-border);"></div>
        <%= link_to new_course_path, class: "studs-nav-btn", data: { turbo_frame: "_top" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
          </svg>
          New course
        <% end %>
      </div>
    </div>
  <% end %>
  <!-- Searchable list in a turbo frame -->
  <%= turbo_frame_tag "courses_list" do %>
    <div class="overflow-hidden rounded-2xl"
         style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg-2);">
      <% if @courses.any? %>
        <% @courses.each_with_index do |course, i| %>
          <% color = course.try(:color).presence || "#34D399" %>
          <% day_labels = { 0 => "Sun", 1 => "Mon", 2 => "Tue", 3 => "Wed", 4 => "Thu", 5 => "Fri", 6 => "Sat" } %>
          <% selected_days = Array(course.repeat_days).sort.map { |d| day_labels[d] }.compact %>
          <% syllabus = course.syllabuses.max_by(&:created_at) %>
          <div class="course-row flex items-start justify-between gap-4 p-4"
               style="border-left: 4px solid <%= color %>;
                      <%= i > 0 ? "border-top: 1px solid var(--studs-divider);" : "" %>">
            <div class="min-w-0 flex-1">
              <p class="font-medium text-zinc-100 truncate min-w-0">
                <%= link_to course.title.presence || "(Untitled)", course_path(course),
                class: "hover:underline underline-offset-2",
                data: { turbo_frame: "_top" } %>
              </p>
              <% details = [course.term.presence, course.professor.presence, course.location.presence].compact %>
              <% if details.any? %>
                <p class="mt-1 text-sm text-zinc-400"><%= details.join(" • ") %></p>
              <% end %>
              <% if course.start_time.present? && course.end_time.present? %>
                <p class="mt-1 text-sm text-zinc-400">
                  <% if selected_days.any? %>
                    <% selected_days.each do |day| %>
                      <span class="inline-block rounded px-1.5 py-0.5 text-[10px] font-semibold mr-0.5"
                            style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-hover); color: var(--studs-accent);">
                        <%= day %>
                      </span>
                    <% end %>
                    <span class="ml-1">
                    <% end %>
                    <%= course.start_time.strftime("%-I:%M%P") %> – <%= course.end_time.strftime("%-I:%M%P") %>
                    <% if selected_days.any? %></span><% end %>
                </p>
              <% end %>
              <% if course.end_date.present? %>
                <p class="mt-1 text-xs text-zinc-500">
                  Until <%= course.end_date.strftime("%b %d, %Y") %>
                </p>
              <% end %>
            </div>
            <div class="flex shrink-0 items-center gap-1.5">
              <%= link_to edit_course_path(course),
                    class: "studs-nav-btn",
                    data: { turbo_frame: "_top" } do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                </svg>
                Edit
              <% end %>
              <%= link_to course_course_items_path(course),
                    class: "studs-nav-btn",
                    data: { turbo_frame: "_top" } do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                </svg>
                Items
              <% end %>
              <% if syllabus.present? %>
                <%= link_to syllabus_path(syllabus),
                      class: "studs-nav-btn",
                      data: { turbo_frame: "_top" } do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12S5.25 6.75 12 6.75 21.75 12 21.75 12 18.75 17.25 12 17.25 2.25 12 2.25 12z"/>
                    <circle cx="12" cy="12" r="2.25"/>
                  </svg>
                  Syllabus
                <% end %>
              <% end %>
              <%= button_to course_path(course),
                    method: :delete,
                    form: { data: { turbo_confirm: "Delete this course?", turbo_frame: "_top" } },
                    class: "studs-nav-btn",
                    style: "border-color: rgba(239,68,68,0.4); color: #fca5a5;" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
                Delete
              <% end %>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="flex flex-col items-center justify-center py-16 text-center">
          <div class="mb-3 opacity-30"><%= icon "course-stroke-rounded", class: "h-10 w-10 text-zinc-300" %></div>
          <% if @q.present? %>
            <p class="text-sm font-medium text-zinc-300">No courses match "<%= @q %>"</p>
            <p class="mt-1 text-xs text-zinc-500">Try a different search term</p>
          <% else %>
            <p class="text-sm font-medium text-zinc-300">No courses yet</p>
            <p class="mt-1 text-xs text-zinc-500">Create your first course to get started</p>
            <div class="mt-4">
              <%= link_to new_course_path, class: "studs-nav-btn", data: { turbo_frame: "_top" } do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                </svg>
                New course
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
