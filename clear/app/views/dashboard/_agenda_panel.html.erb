<% occs = Array(occurrences) %>
<% planner_tasks = Array(local_assigns[:planner_tasks]) %>
<style>
  [data-planner-chip] {
    background-color: var(--bg-normal);
    transition:
      background-color 0.15s ease,
      box-shadow 0.15s ease,
      filter 0.15s ease;
  }

  [data-planner-chip]:hover {
    background-color: var(--bg-hover);
    filter: brightness(1.08);
  }
</style>
<div class="h-full w-full flex flex-col"
     data-controller="agenda-highlight"
     data-agenda-count="<%= occs.size %>">
  <!-- Header -->
  <div class="px-4 py-3 studs-topbar">
    <div class="flex items-center justify-between">
      <div class="min-w-0">
        <div class="text-sm font-semibold text-zinc-100">Agenda</div>
        <div class="mt-0.5 text-xs text-zinc-400">
          <%= date.strftime("%A, %B %-d") %>
          <% todays_occs = occs.select { |o|
              o.respond_to?(:starts_at) &&
              o.starts_at.present? &&
              o.starts_at.in_time_zone.to_date == Time.zone.today
            } %>
          <% if todays_occs.any? %>
            • <%= todays_occs.size %> item<%= "s" if todays_occs.size != 1 %>
          <% end %>
        </div>
        <% if next_occurrence %>
          <div class="mt-1.5 flex items-center gap-1.5 min-w-0 text-xs text-zinc-400"
               data-controller="countdown"
               data-countdown-event-time-value="<%= next_occurrence.starts_at.iso8601 %>">
            <span class="shrink-0 inline-block h-1.5 w-1.5 rounded-full animate-pulse" style="background-color: var(--studs-accent);"></span>
            <span class="shrink-0">Next:</span>
            <span class="font-medium text-zinc-200 truncate min-w-0"><%= next_occurrence.title %></span>
            <span class="shrink-0 mx-0.5 text-zinc-600">—</span>
            <span data-countdown-display class="shrink-0 font-mono tabular-nums" style="color: var(--studs-accent);">...</span>
          </div>
        <% end %>
      </div>
      <button
        type="button"
        class="studs-nav-btn"
        data-action="click->agenda-highlight#clear click->agenda-drawer#close"
        >
        Close
      </button>
    </div>
  </div>
  <!-- Body -->
  <div class="flex-1 min-h-0 bg-zinc-950/95 flex flex-col">
    <%# Tabbed planner palette: switch between dragging unscheduled Tasks and
        Routine blocks onto the calendar. The whole widget self-hides unless a
        day/week grid is visible (see palette_tabs_controller). %>
    <div data-controller="palette-tabs" data-palette-tabs-active-value="tasks"
         class="flex-1 min-h-0 flex flex-col">
      <div data-palette-tabs-target="widget" class="flex-1 min-h-0 flex flex-col px-3 pt-3 pb-3">
        <%# Segmented control — matches the analytics/dashboard page tabs %>
        <div class="mb-3 flex items-center justify-between gap-2 shrink-0">
          <div class="flex gap-1 rounded-xl p-1"
               style="background-color: var(--studs-panel-bg); border: 1px solid var(--studs-border);">
            <button type="button"
                    data-palette-tabs-target="tab" data-tab="tasks"
                    data-action="click->palette-tabs#select"
                    class="rounded-lg px-3 py-1 text-sm transition-colors">
              Tasks
            </button>
            <button type="button"
                    data-palette-tabs-target="tab" data-tab="blocks"
                    data-action="click->palette-tabs#select"
                    class="rounded-lg px-3 py-1 text-sm transition-colors">
              Routine blocks
            </button>
          </div>
          <div class="text-[11px] text-zinc-500 shrink-0">drag onto calendar</div>
        </div>

        <%# Tasks panel — glassy, color-tinted cards (same look as the calendar),
            draggable onto the grid. %>
        <div data-palette-tabs-target="panel" data-tab="tasks" class="flex-1 min-h-0 overflow-auto">
          <div data-controller="task-palette"
               data-task-palette-hour-height-value="72"
               data-task-palette-snap-minutes-value="15">
            <div data-task-palette-target="palette">
              <% if planner_tasks.empty? %>
                <div class="rounded-xl border px-3 py-2 text-xs text-zinc-400"
                     style="border-color: var(--studs-border);">
                  No unscheduled tasks.
                </div>
              <% else %>
                <div class="space-y-2">
                  <% planner_tasks.each do |task| %>
                    <% c = task.color.presence || "#34D399" %>
                    <div
                      data-task-palette-target="chip"
                      data-task-id="<%= task.id %>"
                      data-duration-minutes="<%= task.duration_minutes %>"
                      data-reschedule-url="<%= reschedule_task_path(task) %>"
                      data-action="pointerdown->task-palette#startDrag"
                      data-planner-chip
                      class="cursor-grab select-none rounded-2xl border p-3 backdrop-blur-sm"
                      style="--bg-normal: <%= rgba(c, 0.14) %>; --bg-hover: <%= rgba(c, 0.20) %>; border-color: <%= rgba(c, 0.35) %>; border-left: 6px solid <%= rgba(c, 0.90) %>;"
                    >
                      <div class="flex items-center gap-2 min-w-0">
                        <span class="shrink-0 inline-flex h-2.5 w-2.5 rounded-full" style="background-color: <%= rgba(c, 0.90) %>"></span>
                        <div class="truncate text-sm font-semibold text-zinc-50"><%= task.title.presence || "(Untitled)" %></div>
                      </div>
                      <div class="mt-1 text-xs font-medium text-zinc-200/90"><%= task.duration_minutes %> min</div>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        </div>

        <%# Routine blocks panel — dashed-hatch template chips, draggable %>
        <div data-palette-tabs-target="panel" data-tab="blocks" class="flex-1 min-h-0 overflow-auto">
          <div data-controller="block-palette"
               data-block-palette-create-url-value="<%= blocks_path %>"
               data-block-palette-hour-height-value="72"
               data-block-palette-snap-minutes-value="15">
            <div data-block-palette-target="palette">
              <div class="space-y-2">
                <% [["Study", "#6366f1", 120], ["Deep Work", "#10b981", 120], ["Errands", "#f59e0b", 60]].each do |blk_label, blk_color, blk_dur| %>
                  <div
                    data-block-palette-target="chip"
                    data-label="<%= blk_label %>"
                    data-color="<%= blk_color %>"
                    data-duration-minutes="<%= blk_dur %>"
                    data-action="pointerdown->block-palette#startDrag"
                    class="cursor-grab select-none rounded-xl px-3 py-2 text-sm font-medium text-zinc-100"
                    style="border: 1.5px dashed <%= blk_color %>88; background: repeating-linear-gradient(45deg, <%= blk_color %>22 0, <%= blk_color %>22 7px, <%= blk_color %>0d 7px, <%= blk_color %>0d 16px);">
                    <span class="align-middle"><%= blk_label %></span>
                    <span class="ml-1 align-middle text-xs text-zinc-400"><%= blk_dur %>m</span>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
