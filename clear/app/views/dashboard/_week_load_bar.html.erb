<%#
  Week Load bar — mirrors the analytics "Week Load" bar but uses the daily-bar
  color thresholds (>=75 red, >=50 amber, else accent). Recomputes from `events`
  (visible-week occurrences, already draft-aware) so it updates whenever the
  dashboard_calendar turbo frame is replaced.

  Locals:
    events     — visible-week occurrences (already includes draft preview)
    draft      — active CalendarDraft or nil
    start_date — Date in the visible week
%>
<% week_start = start_date.to_date.beginning_of_week %>
<% week_end   = week_start + 6.days %>
<% in_week_events = events.reject do |o|
     next true if o.is_a?(CourseItem)
     next true if o.respond_to?(:draft_status) && o.draft_status == "deleted"
     next true if o.starts_at.nil?
     d = o.starts_at.in_time_zone.to_date
     d < week_start || d > week_end
   end %>
<% week_minutes = in_week_events.sum { |o|
     o.ends_at && o.starts_at ? [ (o.ends_at - o.starts_at) / 60.0, 0 ].max.to_i : 0
   } %>
<% max_week_minutes = AnalyticsController::MAX_DAILY_MINUTES * 5 %>
<% week_pct = [ (week_minutes.to_f / max_week_minutes * 100), 100 ].min.round(1) %>
<% bar_color =
     if week_pct >= 75 then '#ef4444'
     elsif week_pct >= 50 then '#f59e0b'
     else 'var(--studs-accent)' end %>
<% draft_active = local_assigns[:draft].present? %>

<div class="rounded-2xl px-4 py-3 mb-4"
     style="border: 1px solid <%= draft_active ? 'rgba(252,211,77,0.55)' : 'var(--studs-border)' %>;
            background-color: var(--studs-panel-bg);">
  <div class="flex items-center justify-between mb-1.5">
    <span class="text-xs font-semibold text-zinc-300">
      Week Load<% if draft_active %> <span class="text-amber-300/80">(Draft)</span><% end %>
    </span>
    <span class="text-xs font-semibold" style="color: <%= bar_color %>;">
      <%= week_pct.round %>% of a typical 5-day week
    </span>
  </div>
  <div class="h-2 w-full rounded-full overflow-hidden" style="background-color: var(--studs-border);">
    <div class="analytics-bar h-full rounded-full transition-all duration-700"
         style="width: <%= week_pct %>%; background-color: <%= bar_color %>;"></div>
  </div>
</div>
