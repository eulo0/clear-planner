<% content_for :page_title, "Calendar" %>
<%# Must live in the page head (content_for :head) — Turbo Drive only reads the
    turbo-cache-control meta from the head. Without it, Turbo caches /calendar and previews a
    stale (e.g. weekly) snapshot when you navigate back, flashing the wrong view before the
    fresh server render paints. %>
<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>
<div
  class="-mx-6 -my-6 min-h-0 relative"
  style="height: calc(100% + 3rem)"
  data-controller="agenda-drawer"
  data-agenda-drawer-url-value="<%= dashboard_agenda_path %>"
>
  <div class="flex h-full min-h-0 min-w-0 p-4">
    <section class="min-w-0 w-full flex-1 min-h-0 h-full">
      <%= render "dashboard/calendar_frame",
        view: @view,
        year_calendar: @year_calendar,
        events: @occurrences,
        draft: @draft,
        start_date: @start_date,
        month_events_by_date: @month_events_by_date,
        month_date: @month_date,
        courses: @courses,
        course_filter_id: @course_filter_id %>
    </section>
    <%# Spacer reserves room in the flow so the calendar is pushed narrower. The
        real panel (below) is position:fixed so it stays pinned to the viewport
        as the page scrolls — the weekly/daily calendar page-scrolls by design. %>
    <div
      data-agenda-drawer-target="spacer"
      class="shrink-0 transition-all duration-300 ease-in-out"
      style="width: 0px;"
    ></div>
  </div>
  <%# Fixed agenda panel — pinned to the viewport (top below the header, gaps on
      right/bottom) so it persists in view through page scroll. Width animates. %>
  <div
    data-agenda-drawer-target="panel"
    class="fixed right-4 z-30 overflow-hidden rounded-2xl shadow-2xl transition-all duration-300 ease-in-out"
    style="top: 5rem; bottom: 1rem; width: 0px; visibility: hidden; border: 1px solid var(--studs-border); background-color: var(--studs-sidebar-bg);"
  >
    <%= turbo_frame_tag "agenda_drawer",
          class: "block h-full w-full",
          data: {
            agenda_drawer_target: "frame",
            action: "turbo:before-fetch-request->agenda-drawer#showSkeleton turbo:frame-load->agenda-drawer#frameLoaded"
          } do %>
    <% end %>
  </div>
  <!-- Skeleton -->
  <template data-agenda-drawer-target="skeleton">
    <%= render "dashboard/agenda_drawer_skeleton" %>
  </template>
</div>
