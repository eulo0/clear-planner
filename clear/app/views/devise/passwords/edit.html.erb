<div class="mx-auto flex min-h-[calc(100vh-4rem)] w-full max-w-6xl items-center justify-center px-6 py-12">
  <div class="w-full max-w-md rounded-3xl border border-zinc-800 bg-zinc-900/40 p-8 shadow-2xl shadow-black/30 backdrop-blur-md">
    <div class="mb-8">
      <h1 class="text-2xl font-bold tracking-tight text-zinc-50">Choose a new password</h1>
      <p class="mt-1 text-sm text-zinc-500">Make it something you'll remember.</p>
    </div>

    <%= form_for(resource,
          as: resource_name,
          url: password_path(resource_name),
          html: { method: :put, data: { turbo: false } }) do |f| %>

      <%= render "devise/shared/flash_messages" %>

      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div class="space-y-5">
        <div class="relative">
          <%= f.label :password, "New password", class: "text-sm font-medium text-zinc-300" %>
          <%= f.password_field :password,
                id: "new-password",
                autofocus: true,
                autocomplete: "new-password",
                class: "mt-2 w-full rounded-xl border border-zinc-800 bg-zinc-950/60 px-4 py-2.5 text-sm text-zinc-100 placeholder-zinc-600 backdrop-blur-sm transition-colors duration-200 focus:border-emerald-500/60 focus:outline-none focus:ring-2 focus:ring-emerald-500/20",
                placeholder: "your new password" %>

                <button type="button"
                  id="toggle_password"
                  class="absolute right-3 top-[calc(50%+1rem)] -translate-y-1/2
                        rounded-lg p-1
                        text-zinc-500
                        hover:text-zinc-200
                        hover:bg-zinc-800/60
                        focus:outline-none
                        focus:ring-2 focus:ring-emerald-500/40
                        transition-colors duration-200">

                    <span id="icon-show">
                      <%= icon "eye-stroke-rounded", class: "h-5 w-5 text-emerald-500/40" %>
                    </span>

                    <span id="icon-hide" class="hidden">
                      <%= icon "view-off-slash-stroke-rounded", class: "h-5 w-5 text-emerald-500/40" %>
                    </span>

                </button>
        </div>

        <div class="relative">
          <%= f.label :password_confirmation, "Confirm new password", class: "text-sm font-medium text-zinc-300" %>
          <%= f.password_field :password_confirmation,
                id: "confirm-password",
                autocomplete: "new-password",
                class: "mt-2 w-full rounded-xl border border-zinc-800 bg-zinc-950/60 px-4 py-2.5 text-sm text-zinc-100 placeholder-zinc-600 backdrop-blur-sm transition-colors duration-200 focus:border-emerald-500/60 focus:outline-none focus:ring-2 focus:ring-emerald-500/20",
                placeholder: "re-type new password" %>

                <button type="button"
                  id="toggle_confirm_password"
                  class="absolute right-3 top-[calc(50%+1rem)] -translate-y-1/2
                        rounded-lg p-1
                        text-zinc-500
                        hover:text-zinc-200
                        hover:bg-zinc-800/60
                        focus:outline-none
                        focus:ring-2 focus:ring-emerald-500/40
                        transition-colors duration-200">

                    <span id="confirm-icon-show">
                      <%= icon "eye-stroke-rounded", class: "h-5 w-5 text-emerald-500/40" %>
                    </span>

                    <span id="confirm-icon-hide" class="hidden">
                      <%= icon "view-off-slash-stroke-rounded", class: "h-5 w-5 text-emerald-500/40" %>
                    </span>

                </button>
        </div>

        <%= f.submit "Update password",
              class: "studs-btn-accent mt-3 !w-full !rounded-xl !py-2.5 !text-sm" %>
      </div>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const button = document.getElementById("toggle_password");
    const password = document.getElementById("new-password");
    const showIcon = document.getElementById("icon-show");
    const hideIcon = document.getElementById("icon-hide");

    button.addEventListener("click", () => {
      const isHidden = password.type === "password";

      password.type = isHidden ? "text" : "password";
      showIcon.classList.toggle("hidden", isHidden);
      hideIcon.classList.toggle("hidden", !isHidden);
    });
  });

  document.addEventListener("DOMContentLoaded", () => {
    const button = document.getElementById("toggle_confirm_password");
    const password = document.getElementById("confirm-password");
    const showIcon = document.getElementById("confirm-icon-show");
    const hideIcon = document.getElementById("confirm-icon-hide");

    button.addEventListener("click", () => {
      const isHidden = password.type === "password";

      password.type = isHidden ? "text" : "password";
      showIcon.classList.toggle("hidden", isHidden);
      hideIcon.classList.toggle("hidden", !isHidden);
    });
  });
</script>
