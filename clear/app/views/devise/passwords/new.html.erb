<div class="mx-auto flex min-h-[calc(100vh-4rem)] w-full max-w-6xl items-center justify-center px-6 py-12">
  <div class="w-full max-w-md rounded-3xl border border-zinc-800 bg-zinc-900/40 p-8 shadow-2xl shadow-black/30 backdrop-blur-md">
    <div class="mb-8">
      <h1 class="text-2xl font-bold tracking-tight text-zinc-50">Reset your password</h1>
      <p class="mt-1 text-sm text-zinc-500">We'll email you a reset link.</p>
    </div>

    <%= form_for(resource,
          as: resource_name,
          url: password_path(resource_name),
          html: { method: :post, data: { turbo: false } }) do |f| %>

      <%= render "devise/shared/flash_messages" %>

      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="space-y-5">
        <div>
          <%= f.label :email, class: "text-sm font-medium text-zinc-300" %>
          <%= f.email_field :email,
                autofocus: true,
                autocomplete: "email",
                class: "mt-2 w-full rounded-xl border border-zinc-800 bg-zinc-950/60 px-4 py-2.5 text-sm text-zinc-100 placeholder-zinc-600 backdrop-blur-sm transition-colors duration-200 focus:border-emerald-500/60 focus:outline-none focus:ring-2 focus:ring-emerald-500/20",
                placeholder: "your email" %>
        </div>

        <%= f.submit "Send reset link",
              class: "studs-btn-accent mt-3 !w-full !rounded-xl !py-2.5 !text-sm" %>
      </div>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</div>
