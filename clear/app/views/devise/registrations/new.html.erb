<div class="mx-auto flex min-h-[calc(100vh-4rem)] w-full max-w-6xl items-center justify-center px-6 py-12">
  <div class="w-full max-w-md rounded-3xl border border-zinc-800 bg-zinc-900/40 p-8 shadow-2xl shadow-black/30 backdrop-blur-md">
    <div class="mb-8">
      <h1 class="text-2xl font-bold tracking-tight text-zinc-50">Create your account</h1>
      <p class="mt-1 text-sm text-zinc-500">Sign up to access your dashboard.</p>
    </div>

    <%= form_for(resource,
          as: resource_name,
          url: registration_path(resource_name),
          html: { data: { turbo: false } }) do |f| %>
      <% label_classes = "block text-[10px] font-bold uppercase tracking-widest mb-1.5" %>
      <% label_style   = "color: var(--studs-accent); opacity: 0.8;" %>
      <% input_classes = "w-full rounded-xl px-4 py-2.5 text-sm text-zinc-100 placeholder:text-zinc-600 " \
                         "bg-zinc-950/60 focus:outline-none focus:ring-2 transition-all duration-150 border" %>
      <% input_style   = "border-color: var(--studs-border); --tw-ring-color: var(--studs-accent);" %>

      <%= render "devise/shared/flash_messages" %>

      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="space-y-5">
        <div>
          <%= f.label :email, class: label_classes, style: label_style %>
          <%= f.email_field :email,
                autofocus: true,
                autocomplete: "email",
                class: "#{input_classes} mt-2",
                style: input_style,
                placeholder: "your email" %>
        </div>

        <div>
          <%= f.label :username, class: label_classes, style: label_style %>
          <%= f.text_field :username,
                autofocus: true,
                autocomplete: "username",
                class: "#{input_classes} mt-2",
                style: input_style,
                placeholder: "your username" %>
        </div>

        <div class="relative">
          <%= f.label :password, class: label_classes, style: label_style %>
          <%= f.password_field :password,
                id: "current-password",
                autocomplete: "new-password",
                class: "#{input_classes} mt-2",
                style: input_style,
                placeholder: "your password" %>

                <button type="button"
                id="toggle_password"
                class="absolute right-3 top-[calc(50%+1rem)] -translate-y-1/2
                      rounded-lg p-1
                      text-zinc-500
                      hover:text-zinc-200
                      hover:bg-zinc-800/60
                      focus:outline-none
                      focus:ring-2 focus:ring-emerald-500/40
                      transition-colors duration-200">

                  <span id="icon-show">
                    <%= icon "eye-stroke-rounded", class: "h-5 w-5 text-emerald-500/40" %>
                  </span>

                  <span id="icon-hide" class="hidden">
                    <%= icon "view-off-slash-stroke-rounded", class: "h-5 w-5 text-emerald-500/40" %>
                  </span>

                </button>
        </div>

        <div class="relative">
          <%= f.label :password_confirmation, class: label_classes, style: label_style %>
          <%= f.password_field :password_confirmation,
                id: "confirm-password",
                autocomplete: "new-password",
                class: "#{input_classes} mt-2",
                style: input_style,
                placeholder: "re-type password" %>

          <button type="button"
            id="toggle_confirm_password"
            class="absolute right-3 top-[calc(50%+1rem)] -translate-y-1/2
                  rounded-lg p-1
                  text-zinc-500
                  hover:text-zinc-200
                  hover:bg-zinc-800/60
                  focus:outline-none
                  focus:ring-2 focus:ring-emerald-500/40
                  transition-colors duration-200">

              <span id="confirm_icon-show">
                <%= icon "eye-stroke-rounded", class: "h-5 w-5 text-emerald-500/40" %>
              </span>

              <span id="confirm_icon-hide" class="hidden">
                <%= icon "view-off-slash-stroke-rounded", class: "h-5 w-5 text-emerald-500/40" %>
              </span>

          </button>
        </div>

      <div class="relative">
        <%= f.submit "Sign up",
              class: "studs-btn-accent mt-3 !w-full !rounded-xl !py-2.5 !text-sm" %>
      </div>
    <% end %>

    <div class="relative mt-3">
      <%= button_to user_google_oauth2_omniauth_authorize_path,
        method: :post,
        data: { turbo: false },
        class: "flex w-full items-center justify-center gap-3 rounded-xl border border-zinc-700 bg-zinc-800/50 px-4 py-2.5 text-sm font-medium text-zinc-200 transition-colors duration-200 hover:bg-zinc-700/60 focus:outline-none focus:ring-2 focus:ring-emerald-500/40",
        aria: { label: "Sign in with Google" },
        title: "Sign in with Google" do %>
          <svg class="h-5 w-5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Sign in with Google
        <% end %>
    </div>

    <%= render "devise/shared/links" %>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const button = document.getElementById("toggle_password");
    const password = document.getElementById("current-password");
    const showIcon = document.getElementById("icon-show");
    const hideIcon = document.getElementById("icon-hide");

    button.addEventListener("click", () => {
      const isHidden = password.type === "password";

      password.type = isHidden ? "text" : "password";
      showIcon.classList.toggle("hidden", isHidden);
      hideIcon.classList.toggle("hidden", !isHidden);
    });
  });

  document.addEventListener("DOMContentLoaded", () => {
    const button = document.getElementById("toggle_confirm_password");
    const password = document.getElementById("confirm-password");
    const showIcon = document.getElementById("confirm_icon-show");
    const hideIcon = document.getElementById("confirm_icon-hide");

    button.addEventListener("click", () => {
      const isHidden = password.type === "password";

      password.type = isHidden ? "text" : "password";
      showIcon.classList.toggle("hidden", isHidden);
      hideIcon.classList.toggle("hidden", !isHidden);
    });
  });
</script>
