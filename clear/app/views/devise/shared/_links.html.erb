<div class="mt-8 space-y-2.5 text-sm text-zinc-500">
  <% if controller_path != "users/auth" %>
    <div>
      Already have an account?
      <%= link_to "Sign in",
            new_session_path(resource_name),
            data: { turbo: false },
            class: "text-emerald-400 hover:text-emerald-300 underline underline-offset-4 transition-colors duration-200" %>
    </div>
  <% end %>

  <% if devise_mapping.registerable? && controller_name != "registrations" %>
    <div>
      New here?
      <%= link_to "Create account",
            new_registration_path(resource_name),
            data: { turbo: false },
            class: "text-emerald-400 hover:text-emerald-300 underline underline-offset-4 transition-colors duration-200" %>
    </div>
  <% end %>

  <% if devise_mapping.recoverable? && controller_name != "passwords" && controller_name != "registrations" %>
    <div>
      <%= link_to "Forgot your password?",
            new_password_path(resource_name),
            data: { turbo: false },
            class: "text-emerald-400 hover:text-emerald-300 underline underline-offset-4 transition-colors duration-200" %>
    </div>
  <% end %>
</div>
