<% content_for :page_title, "Documents" %>
<% content_for :page_subtitle, "Uploaded documents" %>
<style>
  .document-row { transition: background-color 0.15s ease; }
  .document-row:hover { background-color: var(--studs-panel-hover); }
</style>

<div class="rounded-2xl p-6" style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg);">
  <%= form_with url: documents_path,
                method: :get,
                data: {
                  turbo_frame: "documents_list",
                  controller: "search",
                  search_target: "form"
                } do |f| %>
    <div class="flex items-center justify-between gap-4 mb-5">
      <div class="text-lg font-semibold text-zinc-100">Documents</div>
      <div class="flex items-center gap-1.5">
        <%= render Studs::SearchBarComponent.new(
              class_name: "w-72",
              placeholder: "Search documents…",
              value: params[:q],
              data: {
                search_target: "input",
                action: "input->search#search keydown->search#submit"
              }
            ) %>
        <div class="mx-1 h-5 w-px rounded-full" style="background-color: var(--studs-border);"></div>
        <%= link_to new_document_path, class: "studs-nav-btn", data: { turbo_frame: "_top" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
          </svg>
          New document
        <% end %>
      </div>
    </div>
  <% end %>

  <%= turbo_frame_tag "documents_list" do %>
    <div class="overflow-hidden rounded-2xl"
         style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg-2);">
    <% if @documents.any? %>
      <% @documents.each_with_index do |document, i| %>
        <div class="document-row flex items-start justify-between gap-4 p-4"
             style="<%= i > 0 ? "border-top: 1px solid var(--studs-divider);" : "" %>">
          <div class="min-w-0 flex-1">
            <p class="font-medium text-zinc-100 truncate">
              <%= link_to document.title.presence || "(Untitled)", document_path(document),
                    class: "hover:underline underline-offset-2",
                    data: { turbo_frame: "_top" } %>
            </p>

            <% if document.file.attached? %>
              <p class="mt-1 text-sm text-zinc-400">
                File: <%= document.file.filename.to_s %>
              </p>
            <% end %>
          </div>

          <div class="flex shrink-0 items-center gap-2">
            <%= link_to document_path(document), class: "studs-nav-btn", data: { turbo_frame: "_top" } do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12S5.25 6.75 12 6.75 21.75 12 21.75 12 18.75 17.25 12 17.25 2.25 12 2.25 12z"/>
                <circle cx="12" cy="12" r="2.25"/>
              </svg>
              View
            <% end %>

            <%= button_to document_path(document),
                  method: :delete,
                  form: { data: { turbo_confirm: "Delete this document?", turbo_frame: "_top" } },
                  class: "studs-nav-btn",
                  style: "border-color: rgba(239,68,68,0.4); color: #fca5a5;" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
              </svg>
              Delete
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="flex flex-col items-center justify-center py-16 text-center">
        <div class="mb-3 opacity-30"><%= icon "file-01-stroke-rounded", class: "h-10 w-10 text-zinc-300" %></div>
        <% if @q.present? %>
          <p class="text-sm font-medium text-zinc-300">No documents match "<%= @q %>"</p>
          <p class="mt-1 text-xs text-zinc-500">Try a different search term</p>
        <% else %>
          <p class="text-sm font-medium text-zinc-300">No documents yet</p>
          <p class="mt-1 text-xs text-zinc-500">Upload your first document to get started</p>
          <div class="mt-4">
            <%= link_to new_document_path, class: "studs-nav-btn", data: { turbo_frame: "_top" } do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
              </svg>
              New document
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
    </div>
  <% end %>
</div>
