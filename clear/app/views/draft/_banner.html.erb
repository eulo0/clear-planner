<%= turbo_frame_tag "draft_banner" do %>
  <% draft = local_assigns[:active_draft] %>
  <% start_date = local_assigns[:start_date].presence || Date.current.iso8601 %>

  <% if draft.present? %>
    <div class="mb-3 flex items-center gap-3 rounded-xl border border-amber-300/65 bg-amber-500/16 px-4 py-2.5 text-sm text-amber-100 shadow-[0_0_0_1px_rgba(251,191,36,0.26)]"
         data-controller="draft-cache">
      <span class="flex items-center gap-2 font-semibold">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-amber-300"></span>
        <%= draft.name %>
      </span>
      <span class="inline-flex items-center rounded-lg border border-amber-300/65 bg-amber-500/16 px-2 py-0.5 text-[11px] font-medium text-amber-100">
        <%= draft.operation_count %> pending <%= "change".pluralize(draft.operation_count) %>
      </span>
      <div class="ml-auto flex items-center gap-2">
        <%= button_to "Apply",
              apply_draft_path(start_date: start_date),
              method: :patch,
              class: "inline-flex items-center rounded-lg border border-emerald-500/40 bg-emerald-500/20 px-3 py-1.5 text-xs font-semibold text-emerald-100 hover:bg-emerald-500/30 transition cursor-pointer" %>
        <%= button_to "Discard",
              discard_draft_path(start_date: start_date),
              method: :delete,
              data: { turbo_confirm: "Discard all #{draft.operation_count} pending changes?" },
              class: "inline-flex items-center rounded-lg border border-red-500/40 bg-red-500/15 px-3 py-1.5 text-xs font-semibold text-red-200 hover:bg-red-500/25 transition cursor-pointer" %>
        <%= button_to "×",
              exit_draft_path(start_date: start_date),
              method: :patch,
              data: { action: "click->draft-cache#clearSearch" },
              aria: { label: "Exit draft mode" },
              title: "Exit draft mode",
              class: "inline-flex h-7 w-7 items-center justify-center rounded-lg border border-amber-300/65 bg-amber-500/16 text-sm font-semibold leading-none text-amber-100 hover:bg-amber-500/25 transition cursor-pointer" %>
      </div>
    </div>
  <% end %>
<% end %>
