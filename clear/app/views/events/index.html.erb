<% content_for :page_title, "Events" %>
<% content_for :page_subtitle, "Upcoming and past events" %>
<style>
  .event-row { transition: background-color 0.15s ease; }
  .event-row:hover { background-color: var(--studs-panel-hover); }
</style>
<div class="rounded-2xl p-6" style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg);">
  <!-- Header with search -->
  <%= form_with url: events_path,
                method: :get,
                data: {
                  turbo_frame: "events_list",
                  controller: "search",
                  search_target: "form"
                } do |f| %>
    <div class="flex items-center justify-between gap-4 mb-5">
      <div class="text-lg font-semibold text-zinc-100">Events</div>
      <div class="flex items-center gap-1.5">
        <%= render Studs::SearchBarComponent.new(
              class_name: "w-72",
              placeholder: "Search events…",
              value: params[:q],
              data: {
                search_target: "input",
                action: "input->search#search keydown->search#submit"
              }
            ) %>
        <div class="mx-1 h-5 w-px rounded-full" style="background-color: var(--studs-border);"></div>
        <%= link_to destroy_all_events_path,
              class: "studs-nav-btn",
              style: "border-color: rgba(239,68,68,0.4); color: #fca5a5;",
              data: { turbo_method: :delete, turbo_confirm: "Delete all events? This cannot be undone." } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
          Delete all
        <% end %>
        <div class="mx-1 h-5 w-px rounded-full" style="background-color: var(--studs-border);"></div>
        <%= link_to university_calendar_preview_path, class: "studs-nav-btn", data: { turbo_frame: "_top" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          Import from University Calendar
        <% end %>
        <div class="mx-1 h-5 w-px rounded-full" style="background-color: var(--studs-border);"></div>
        <%= link_to new_event_path, class: "studs-nav-btn", data: { turbo_frame: "_top" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
          </svg>
          New event
        <% end %>
      </div>
    </div>
  <% end %>
  <!-- Searchable list in a turbo frame -->
  <%= turbo_frame_tag "events_list" do %>
    <div class="overflow-hidden rounded-2xl"
         style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg-2);">
      <% occurrences = (@occurrences || @events || []) %>
      <% if occurrences.any? %>
        <% occurrences.each_with_index do |occ, i| %>
          <% event     = occ.respond_to?(:event) ? occ.event : occ %>
          <% starts_at = occ.respond_to?(:starts_at) ? occ.starts_at : event.starts_at %>
          <% ends_at   = occ.respond_to?(:ends_at)   ? occ.ends_at   : event.ends_at %>
          <% color     = event.color.presence || "#34D399" %>
          <div class="event-row flex items-start justify-between gap-4 p-4"
               style="border-left: 4px solid <%= color %>;
                      <%= i > 0 ? "border-top: 1px solid var(--studs-divider);" : "" %>">
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2 flex-wrap">
                <p class="font-medium text-zinc-100 min-w-0 truncate max-w-xs sm:max-w-sm md:max-w-md">
                  <%= link_to event.title.presence || "(Untitled)", event_path(event, start_date: starts_at&.to_date),
            class: "hover:underline underline-offset-2",
            data: {
              turbo_frame: "event_drawer",
              action: "click->drawer#start",
              turbo_prefetch: false
            } %>
                </p>
                <% if event.project_id.present? %>
                  <span class="shrink-0 truncate max-w-[8rem] text-sm text-zinc-400">
                    <%= Project.find(event.project_id).title %>
                  </span>
                <% end %>
                <% if event.recurring? %>
                  <span class="rounded-full px-2 py-0.5 text-[10px] font-semibold"
            style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-hover); color: var(--studs-accent);">
                    ↻ Repeats
                  </span>
                <% end %>
                <% if event.priority.present? %>
                  <span class="rounded-full px-2 py-0.5 text-[10px] font-semibold bg-zinc-800 text-zinc-300">
                    P<%= event.priority %>
                  </span>
                <% end %>
              </div>
              <p class="mt-1 text-sm text-zinc-400">
                <%= starts_at&.strftime("%b %d, %Y • %I:%M %p") %>
                <% if ends_at.present? %>
                  – <%= ends_at.strftime("%I:%M %p") %>
                <% end %>
              </p>
              <% if event.location.present? %>
                <p class="text-sm text-zinc-500">📍 <%= event.location %></p>
              <% end %>
              <% if event.recurring? && event.repeat_until.present? %>
                <p class="mt-1 text-xs text-zinc-500">
                  Until <%= event.repeat_until.strftime("%b %d, %Y") %>
                </p>
              <% end %>
            </div>
            <div class="flex shrink-0 items-center gap-1.5">
              <%= link_to edit_event_path(event),
                    class: "studs-nav-btn",
                    data: { turbo_frame: "_top" } do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                </svg>
                Edit
              <% end %>
              <%= button_to event_path(event),
                    method: :delete,
                    form: { data: { turbo_confirm: "Delete this event?", turbo_frame: "_top" } },
                    class: "studs-nav-btn",
                    style: "border-color: rgba(239,68,68,0.4); color: #fca5a5;" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
                Delete
              <% end %>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="flex flex-col items-center justify-center py-16 text-center">
          <div class="mb-3 text-4xl opacity-30">📅</div>
          <% if @q.present? %>
            <p class="text-sm font-medium text-zinc-300">No events match "<%= @q %>"</p>
            <p class="mt-1 text-xs text-zinc-500">Try a different search term</p>
          <% else %>
            <p class="text-sm font-medium text-zinc-300">No events yet</p>
            <p class="mt-1 text-xs text-zinc-500">Create your first event to get started</p>
            <div class="mt-4">
              <%= link_to new_event_path, class: "studs-nav-btn", data: { turbo_frame: "_top" } do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                </svg>
                New event
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
    <% if @pagy&.pages.to_i > 1 %>
      <% pages      = @pagy.pages %>
      <% page       = @pagy.page %>
      <% prev_page  = page > 1       ? page - 1 : nil %>
      <% next_page  = page < pages   ? page + 1 : nil %>
      <div class="flex items-center justify-between px-4 py-3 mt-2">
        <p class="text-xs text-zinc-500">Page <%= page %> of <%= pages %></p>
        <div class="flex items-center gap-1.5">
          <%= link_to "← Prev",
                (prev_page ? events_path(page: prev_page, q: @q) : "#"),
                class: [
                  "studs-nav-btn",
                  prev_page ? "" : "opacity-40 pointer-events-none"
                ].join(" ") %>
          <% ([page - 2, 1].max..[page + 2, pages].min).each do |p| %>
            <%= link_to p, events_path(page: p, q: @q),
                  class: [
                    "studs-nav-btn",
                    p == page ? "font-bold" : ""
                  ].join(" ") %>
          <% end %>
          <%= link_to "Next →",
                (next_page ? events_path(page: next_page, q: @q) : "#"),
                class: [
                  "studs-nav-btn",
                  next_page ? "" : "opacity-40 pointer-events-none"
                ].join(" ") %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
