<%# Turbo-frame fallback: if the Turbo-Frame request header is stripped (e.g. by a
    proxy/CDN), the show action falls through to this template. Including the drawer
    partial here ensures the event_drawer frame is always present in the response so
    Turbo updates the panel rather than doing a full-page navigation. %>
<div hidden><%= render "events/drawer_detail", event: @event, start_date: params[:start_date] %></div>
<% content_for :page_title, @event.title.presence || "Event" %>
<% content_for :page_subtitle, "Event details" %>
<% color = @event.color.presence || "#34D399" %>
<div class="space-y-4">
  <!-- Header card -->
  <div class="rounded-2xl p-6"
       style="border: 1px solid var(--studs-border);
              background-color: var(--studs-panel-bg);
              border-left: 4px solid <%= color %>;">
    <div class="flex items-start justify-between gap-4">
      <div class="min-w-0 flex-1">
        <h1 class="text-2xl font-bold text-zinc-100 truncate">
          <%= @event.title.presence || "(Untitled)" %>
        </h1>
        <div class="mt-3 flex flex-wrap gap-4 text-sm text-zinc-400">
          <span class="flex items-center gap-1.5">
            <svg class="h-4 w-4 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <%= @event.starts_at&.strftime("%B %d, %Y") %>
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="h-4 w-4 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <%= @event.starts_at&.strftime("%-I:%M %p") %>
            <% if @event.ends_at.present? %>
              <span class="text-zinc-600">–</span>
              <%= @event.ends_at.strftime("%-I:%M %p") %>
            <% end %>
          </span>
          <% if @event.location.present? %>
            <span class="flex items-center gap-1.5">
              <svg class="h-4 w-4 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <%= @event.location %>
            </span>
          <% end %>
          <% if @event.priority.present? %>
            <span class="flex items-center gap-1.5">
              <svg class="h-4 w-4 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 3l14 9-14 9V3z"/>
              </svg>
              Priority <%= @event.priority %>
            </span>
          <% end %>
        </div>
        <% if @event.recurring? %>
          <div class="mt-3 inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-semibold"
               style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-hover); color: var(--studs-accent);">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
            Repeats
            <% if @event.repeat_until.present? %>
              until <%= @event.repeat_until.strftime("%b %-d, %Y") %>
            <% end %>
          </div>
        <% end %>
      </div>
      <div class="flex shrink-0 items-center gap-1.5">
        <%= link_to edit_event_path(@event), class: "studs-nav-btn" do %>
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
          </svg>
          Edit
        <% end %>
        <%= button_to event_path(@event),
              method: :delete,
              form: { data: { turbo_confirm: "Delete this event?" } },
              class: "studs-nav-btn",
              style: "border-color: rgba(239,68,68,0.4); color: #fca5a5;" do %>
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
          Delete
        <% end %>
      </div>
    </div>
  </div>
  <!-- Description card -->
  <div class="rounded-2xl p-5"
       style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg-2);">
    <div class="text-[10px] font-bold uppercase tracking-widest mb-3"
         style="color: var(--studs-accent); opacity: 0.8;">Description</div>
    <% if @event.description.present? %>
      <p class="whitespace-pre-wrap text-sm text-zinc-200 leading-relaxed"><%= @event.description %></p>
    <% else %>
      <p class="text-sm text-zinc-500">No description provided.</p>
    <% end %>
  </div>
  <!-- Footer actions -->
  <div class="flex items-center gap-1.5 pt-2" style="border-top: 1px solid var(--studs-divider);">
    <% path = @event.project.present? ? project_path(@event.project) : dashboard_path %>
    <%= link_to path, class: "studs-nav-btn" do %>
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      <%if @event.project.present? %>
        Back to project
      <% else %>
        Back to dashboard
      <% end %>
    <% end %>
    <%= link_to events_path, class: "studs-nav-btn" do %>
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16"/>
      </svg>
      All events
    <% end %>
  </div>
</div>
