<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= content_for(:title) || "Clear" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Clear">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%= favicon_link_tag "logo-favicon.png", rel: "icon", type: "image/png" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>
  <body data-theme="<%= user_signed_in? ? current_user.theme : 'green' %>" class="h-full overflow-hidden bg-zinc-950 text-zinc-100">
    <div data-controller="sidebar drawer ai-chat-drawer"
         data-ai-chat-drawer-url-value="<%= panel_ai_chat_index_path %>"
         class="flex h-full min-h-0 overflow-hidden">
      <aside
        data-sidebar-target="sidebar"
        data-collapsed="false"
        style="background-color: var(--studs-sidebar-bg); border-right: 1px solid var(--studs-border);"
        class="group/sidebar flex h-full flex-col overflow-hidden
               w-64 data-[collapsed=true]:w-16 transition-all duration-300"
      >
        <div class="shrink-0 flex items-center gap-3 px-3 py-3"
             style="border-bottom: 1px solid var(--studs-border-subtle);">
          <button
            type="button"
            data-action="sidebar#toggle"
            class="inline-flex h-9 w-9 items-center justify-center rounded-lg
                   hover:bg-white/5 transition-all duration-200
                   text-zinc-400 hover:text-zinc-100
                   [&_svg]:text-current
                   [&_svg_*]:stroke-current
                   [&_svg_*]:fill-none"
            aria-label="Toggle navigation"
          >
            <span class="[&>svg]:h-5 [&>svg]:w-5">
              <%= icon "menu-01-stroke-rounded" %>
            </span>
          </button>
          <div class="min-w-0 group-data-[collapsed=true]/sidebar:hidden">
            <div class="text-lg font-bold tracking-tight text-zinc-100 truncate">Clear</div>
          </div>
        </div>
        <!-- Sidebar content -->
        <div class="flex-1 min-h-0 overflow-y-auto">
          <%= render Studs::LeftNavComponent.new(
            brand: nil,
            items: (
              [
                { label: "Dashboard",   path: "/dashboard",   icon_name: "dashboard-circle-stroke-rounded" },
                { label: "Schedule",    path: "/schedule",    icon_name: "calendar-02-stroke-rounded" },
                { label: "Agenda",      path: "/agenda",      icon_name: "view-agenda-stroke-rounded" },
                { label: "Analytics",   path: "/analytics",   icon_name: "eye-stroke-rounded" },
                { label: "Courses",     path: "/courses",     icon_name: "course-stroke-rounded" },
                { label: "Events",      path: "/events",      icon_name: "timeline-event-stroke-rounded" },
                { label: "Projects",    path: "/projects",    icon_name: "file-01-stroke-rounded" },
                { label: "Work Shifts", path: "/work_shifts", icon_name: "apartment-stroke-rounded" },
              ] +
              (current_user&.admin? ? [
                { label: "Users", path: "/admin/users", icon_name: "user-02-stroke-rounded" }
              ] : [])
            ),
            settings_items: [
              { label: "Profile", path: profile_path, icon_name: "user-02-stroke-rounded",
                data: { turbo_frame: "profile_modal", turbo_prefetch: false, action: "click->modal#start" } }
            ] +
            (current_user&.admin? ? [
              { label: "UI Kit", path: "/ui", icon_name: "search-01-stroke-rounded" }
            ] : []),
            class_name: "h-full"
          ) %>
        </div>
      </aside>
      <!-- RIGHT COLUMN (top bar + page content) -->
      <div class="flex min-w-0 flex-1 flex-col overflow-hidden relative">
        <!-- Top bar -->
        <header class="shrink-0">
          <%= render Studs::TopBarComponent.new(
                title: (content_for?(:page_title) ? yield(:page_title) : "Dashboard"),
                subtitle: (content_for?(:page_subtitle) ? yield(:page_subtitle) : nil)
              ) do |t| %>
            <% t.with_actions do %>
              <% unread_count = user_signed_in? ? current_user.notifications.unread.count : 0 %>
              <% draft_start_date = params[:start_date].presence || Date.current.iso8601 %>
              <% active_draft = user_signed_in? ? current_user_draft : nil %>
              <% drafts = user_signed_in? ? current_user_drafts : [] %>
              <div class="flex items-center gap-2">
                <%= render "draft/toggle",
                      start_date: draft_start_date,
                      active_draft: active_draft,
                      drafts: drafts,
                      max_drafts: CalendarDraft::MAX_DRAFTS_PER_USER %>
                <div class="mx-1 h-5 w-px rounded-full" style="background-color: var(--studs-border);"></div>
                <button type="button"
                        data-action="click->ai-chat-drawer#toggle"
                        class="studs-topbar-icon-btn studs-topbar-icon-btn--ai"
                        aria-label="Open AI Chat">
                  <span class="[&>svg]:h-5 [&>svg]:w-5">
                    <%= icon "chat-bot-stroke-rounded" %>
                  </span>
                </button>
                <div class="mx-1 h-5 w-px rounded-full" style="background-color: var(--studs-border);"></div>
                <div class="relative" data-controller="notifications-dropdown">
                  <button
                  type="button"
                  data-action="click->notifications-dropdown#toggle"
                    class="studs-topbar-icon-btn studs-topbar-icon-btn--draft"
                    aria-label="Notifications"
                    >
                    <span class="[&>svg]:h-5 [&>svg]:w-5">
                      <%= icon "bell-dot-stroke-rounded" %>
                    </span>
                    <%= render "notifications/badge", unread_count: unread_count %>
                  </button>
                  <%# Dropdown panel %>
                  <div
                  data-notifications-dropdown-target="panel"
                  class="hidden absolute right-0 top-full mt-2 w-96 z-50 rounded-2xl border shadow-2xl overflow-hidden"
                  style="border-color: var(--studs-border); background-color: var(--studs-sidebar-bg);"
                >
                    <%= turbo_frame_tag "notifications_panel",
                        src: notifications_path,
                        loading: :lazy do %>
                      <div class="px-4 py-6 text-center text-sm text-zinc-400">Loading...</div>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          <% end %>
        </header>
        <!-- Page content -->
        <main class="min-w-0 min-h-0 flex-1 overflow-y-auto scrollbars">
          <div class="h-full px-6 py-6">
            <%= yield %>
          </div>
        </main>
        <!-- AI Chat Overlay -->
        <div
          data-ai-chat-drawer-target="overlay"
          data-action="click->ai-chat-drawer#close"
          class="absolute inset-0 z-40 bg-black/60 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300">
        </div>
        <!-- AI Chat Panel -->
        <div
          data-ai-chat-drawer-target="panel"
          role="dialog"
          aria-modal="true"
          class="absolute right-0 inset-y-0 z-50 w-[620px]
                 overflow-hidden shadow-2xl
                 translate-x-full transition-transform duration-300 ease-in-out"
          style="visibility: hidden; border-left: 1px solid var(--studs-border); background-color: var(--studs-sidebar-bg);">
          <%= turbo_frame_tag "ai_chat_drawer",
                class: "block h-full",
                data: { ai_chat_drawer_target: "frame" } do %>
          <% end %>
        </div>
      </div>
      <div id="drawer_events" class="hidden"></div>
      <!-- Event Drawer Overlay -->
      <div
        data-drawer-target="overlay"
        data-action="click->drawer#close"
        class="fixed inset-0 z-40 bg-black/60 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300">
      </div>
      <!-- Event Drawer Panel -->
      <div
        data-drawer-target="panel"
        role="dialog"
        aria-modal="true"
        class="fixed inset-y-0 right-0 z-50
               w-full sm:w-[520px]
               overflow-hidden shadow-2xl
               translate-x-full transition-transform duration-300 ease-in-out"
        style="border-left: 1px solid var(--studs-border); background-color: var(--studs-sidebar-bg);">
        <%= turbo_frame_tag "event_drawer",
              class: "block h-full",
              data: {
                drawer_target: "frame",
                action: "turbo:frame-load->drawer#frameLoaded turbo:submit-end->drawer#submitEnded"
              } do %>
        <% end %>
      </div>
      <!-- Event Drawer Skeleton -->
      <template data-drawer-target="skeleton">
        <%= render "events/drawer_skeleton" %>
      </template>
    </div>
    <!-- Profile Modal -->
    <div data-controller="modal">
      <!-- Profile Modal Overlay -->
      <div
        data-modal-target="overlay"
        data-action="click->modal#close"
        class="fixed inset-0 z-40 bg-black/60 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300">
      </div>
      <!-- Profile Modal Panel -->
      <div
        data-modal-target="panel"
        role="dialog"
        aria-modal="true"
        class="fixed inset-0 z-50 flex items-center justify-center
               opacity-0 scale-95 pointer-events-none
               transition-all duration-300 ease-out">
        <div class="w-full max-w-4xl max-h-[85vh] overflow-hidden rounded-2xl shadow-2xl"
             style="border: 1px solid var(--studs-border); background-color: var(--studs-sidebar-bg);">
          <%= turbo_frame_tag "profile_modal",
                class: "block h-full",
                data: {
                  modal_target: "frame",
                  action: "turbo:frame-load->modal#frameLoaded turbo:submit-end->modal#submitEnded"
                } do %>
          <% end %>
        </div>
      </div>
    </div>
    <!-- Toast notifications -->
    <%= render "shared/toasts" %>
    <script>
      function bindPasswordToggles() {
        document.querySelectorAll('[data-password-toggle]').forEach((button) => {
          if (button.dataset.bound === "true") return;
          button.dataset.bound = "true";

          button.addEventListener("click", () => {
            const input = document.getElementById(button.dataset.target);
            const showIcon = button.querySelector("[data-show]");
            const hideIcon = button.querySelector("[data-hide]");

            const isHidden = input.type === "password";
            input.type = isHidden ? "text" : "password";

            showIcon.classList.toggle("hidden", isHidden);
            hideIcon.classList.toggle("hidden", !isHidden);
          });
        });
      }

      document.addEventListener("turbo:load", bindPasswordToggles);
      document.addEventListener("turbo:frame-load", bindPasswordToggles);
    </script>
  </body>
</html>
