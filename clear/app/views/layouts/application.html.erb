<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Clear" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Clear">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%= favicon_link_tag asset_path("logo-favicon.png"), type: "image/png" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
    <style>
      .home-nav-hover {
        position: relative;
      }

      .home-nav-hover::after {
        content: "";
        position: absolute;
        left: 0;
        bottom: -0.2rem;
        width: 100%;
        height: 1px;
        background-color: currentColor;
        opacity: 0.85;
        transform: scaleX(0);
        transform-origin: center;
        transition: transform 180ms ease;
      }

      .home-nav-hover:hover::after,
      .home-nav-hover:focus-visible::after {
        transform: scaleX(1);
      }
    </style>
  </head>
  <body class="min-h-screen bg-zinc-950 text-zinc-100">
    <% show_public_header =
        controller_name == "home" ||
        (controller.respond_to?(:devise_controller?) && controller.devise_controller?) %>
    <% if show_public_header %>
      <% on_homepage = controller_name == "home" && action_name == "index" %>
      <!-- Public aurora background -->
      <div class="aurora pointer-events-none fixed inset-0 -z-10 overflow-hidden">
        <div class="aurora__gradient"></div>
        <div class="aurora__orb aurora__orb--1"></div>
        <div class="aurora__orb aurora__orb--2"></div>
        <div class="aurora__orb aurora__orb--3"></div>
        <div class="aurora__vignette"></div>
      </div>
      <header class="sticky top-0 z-40 border-b border-zinc-800/60 bg-zinc-950/40 backdrop-blur-xl">
        <div class="mx-auto flex h-[68px] w-full items-center px-6 overflow-visible <%= on_homepage ? 'max-w-[2000px] justify-between relative lg:px-[68px]!' : 'max-w-7xl' %>">
          <%= link_to root_path, class: "flex items-center gap-1 shrink-0" do %>
            <%= image_tag "simple_logo.png",
                          alt: "Clear",
                          class: "-ml-16 h-[56px] w-auto origin-left scale-[1.35] object-contain" %>
            <span class="-mt-1 text-xl font-bold tracking-wide text-zinc-50">Clear</span>
          <% end %>
          <% if on_homepage %>
            <nav class="hidden items-center gap-16 md:flex md:absolute md:left-1/2 md:-translate-x-1/2">
              <%= link_to "Community", "https://discord.gg/wadks6h7F4", rel: "noopener", class: "home-nav-hover text-sm font-medium text-zinc-50 transition hover:text-white" %>
              <%= link_to "Resources", "https://github.com/ChaseDow/senior_capstone/wiki", rel: "noopener", class: "home-nav-hover text-sm font-medium text-zinc-50 transition hover:text-white" %>
            </nav>
            <div class="flex items-center gap-2 mr-[-50px]">
              <%= link_to "Get Started For Free",
                    new_user_registration_path,
                    data: { turbo: false },
                    class: "studs-btn-accent rounded-xl px-4 py-2 text-sm" %>
              <%= link_to "Login",
                    new_user_session_path,
                    data: { turbo: false },
                    class: "studs-nav-btn rounded-xl px-4 py-2 text-sm" %>
            </div>
          <% end %>
        </div>
      </header>
    <% end %>
  <%= render "shared/toasts" if controller_name == "home" %>
    <%= yield %>
  </body>
</html>
