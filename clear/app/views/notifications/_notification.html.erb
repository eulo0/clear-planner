<%# locals: (notification:) %>
<% notifiable = notification.notifiable %>
<% open_path = if %w[assignment_due assignment_reminder].include?(notification.category) && notifiable.is_a?(CourseItem)
     edit_course_course_item_path(notifiable.course, notifiable)
   elsif %w[high_priority event_created event_reminder].include?(notification.category) && notifiable.is_a?(Event)
     event_path(notifiable)
   elsif notification.category == "group_member_joined" && notifiable.is_a?(Project)
     project_path(notifiable)
   end %>
<% category_label = if %w[assignment_due assignment_reminder].include?(notification.category) && notifiable.is_a?(CourseItem)
     notification.category == "assignment_reminder" ? "Due soon" : "#{notifiable.kind.humanize} added"
   else
     {
       "event_created"      => "Event added",
       "course_added"       => "Course added",
       "high_priority"      => "High priority",
       "group"              => "Group",
       "group_member_joined" => "Group",
       "event_reminder"     => "Starting soon",
       "course_reminder"    => "Class starting soon",
       "assignment_reminder" => "Due soon"
     }.fetch(notification.category, notification.category.humanize)
   end %>
<div id="<%= dom_id(notification) %>"
     class="rounded-2xl border px-3 py-3 transition <%= notification.read? ? 'opacity-60' : '' %>"
     style="border-color: var(--studs-border); background-color: var(--studs-panel-header);">
  <div class="flex items-start gap-2.5">
    <%# Read/unread dot + clickable content area %>
    <%= button_to mark_read_notification_path(notification),
          method: :patch,
          class: "flex items-start gap-2.5 w-full text-left cursor-pointer disabled:cursor-default",
          disabled: notification.read?,
          form: { class: "flex-1 min-w-0" } do %>
      <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full <%= notification.read? ? 'bg-zinc-600' : 'bg-rose-500' %>"></span>
      <div class="min-w-0 flex-1">
        <div class="text-sm font-medium text-zinc-100 truncate"><%= notification.message %></div>
        <div class="mt-0.5 flex items-center gap-1.5 text-xs text-zinc-400">
          <span><%= notification.created_at.strftime("%-b %-d at %-I:%M %p") %></span>
          <span class="text-zinc-600">•</span>
          <% if notification.scheduled_for.present? %>
            <span data-controller="countdown" data-countdown-event-time-value="<%= notification.scheduled_for.iso8601 %>">
              <span data-countdown-display></span>
            </span>
          <% else %>
            <span><%= category_label %></span>
          <% end %>
        </div>
      </div>
    <% end %>
    <%= button_to notification_path(notification),
          method: :delete,
          class: "flex items-center justify-center h-6 w-6 rounded-lg text-zinc-500 hover:text-zinc-200 hover:bg-white/10 transition cursor-pointer",
          title: "Dismiss",
          form: { class: "shrink-0 self-start" } do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    <% end %>
  </div>
</div>
