<%= turbo_frame_tag "profile_modal",
      data: {
        modal_target: "frame",
        action: "turbo:frame-load->modal#frameLoaded turbo:submit-end->modal#submitEnded"
      } do %>
  <style>
    [data-profile-nav-link].is-selected {
      background: rgb(255 255 255 / 0.1);
      color: rgb(244 244 245);
    }
  </style>
  <div class="flex h-[85vh] flex-col" data-controller="profile-nav">
    <!-- Header -->
    <div class="flex items-start justify-between border-b border-zinc-800 bg-zinc-950/50 px-6 py-4">
      <div>
        <div class="text-sm font-semibold text-zinc-100">Profile</div>
        <div class="text-xs text-zinc-500">Manage your account and preferences</div>
      </div>
      <button
        type="button"
        data-action="modal#close"
        class="studs-nav-btn">
        ✕
      </button>
    </div>
    <!-- Body -->
    <div class="min-h-0 flex-1 overflow-hidden">
      <div class="grid h-full min-h-0 grid-cols-12">
        <!-- Left nav -->
        <aside class="col-span-3 border-r border-zinc-800 bg-zinc-950/30 p-4 flex flex-col">
          <div class="space-y-1">
            <a href="#account"
               class="studs-nav-btn w-full justify-start"
               data-profile-nav-link
               data-profile-nav-id="account"
               data-profile-nav-target="navLink"
               data-action="click->profile-nav#focus">
              My Account
            </a>
            <a href="#security"
               class="studs-nav-btn w-full justify-start"
               data-profile-nav-link
               data-profile-nav-id="security"
               data-profile-nav-target="navLink"
               data-action="click->profile-nav#focus">
              Security
            </a>
            <a href="#preferences"
               class="studs-nav-btn w-full justify-start"
               data-profile-nav-link
               data-profile-nav-id="preferences"
               data-profile-nav-target="navLink"
               data-action="click->profile-nav#focus">
              Preferences
            </a>
          </div>
          <div class="mt-auto"></div>
          <div class="mt-6 border-t border-zinc-800 pt-4">
            <%= button_to destroy_user_session_path,
                  method: :delete,
                  form: { data: { turbo: false } },
                  class: "studs-nav-btn w-full justify-start" do %>
              Sign out
            <% end %>
          </div>
        </aside>
        <!-- Right content -->
        <section class="col-span-9 h-full min-h-0 p-6 space-y-8 overflow-y-auto" data-profile-nav-target="scroll">
          <!-- Account -->
          <div id="account" data-profile-nav-target="section">
            <div class="text-xs font-semibold uppercase tracking-wide text-zinc-500">User Profile</div>
            <div class="mt-3 rounded-2xl border border-zinc-800 bg-zinc-900/40 p-5">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <!-- avatar -->
                  <div class="h-16 w-16 overflow-hidden rounded-full bg-zinc-900 ring-2" style="--tw-ring-color: var(--studs-border);">
                    <% if user.avatar.attached? %>
                      <%= image_tag user.avatar,
                            class: "h-full w-full",
                            alt: "Profile avatar" %>
                    <% else %>
                      <%= image_tag "default_icon.png",
                            class: "h-full w-full",
                            alt: "Profile avatar" %>
                    <% end %>
                  </div>
                </div>
                <div class="shrink-0">
                  <%= link_to "Change Icon",
                        edit_avatar_profile_path,
                        data: { turbo_frame: "profile_modal", turbo_prefetch: false },
                        class: "studs-nav-btn px-3 py-1.5 text-xs" %>
                </div>
              </div>
              <div class="mt-4 border-t pt-4 space-y-4" style="border-color: var(--studs-divider);">
                <div class="flex items-center justify-between gap-4" data-controller="username-edit">
                  <div>
                    <div class="text-xs text-zinc-400">Username</div>
                    <div id="username_display" data-username-edit-target="display" class="mt-1 text-sm font-medium text-zinc-100"><%= user.username %></div>
                    <%= form_with model: user, url: update_username_profile_path, method: :patch, id: "username_form", class: "mt-1 hidden items-center gap-2", data: { username_edit_target: "form" } do |f| %>
                      <%= f.text_field :username,
                            id: "username_input",
                            class: "w-full max-w-[12rem] rounded-md px-2.5 py-1 text-sm text-zinc-100 placeholder:text-zinc-600 bg-zinc-950/60 focus:outline-none focus:ring-2 transition-all duration-150 border",
                            style: "border-color: var(--studs-border); --tw-ring-color: var(--studs-accent);",
                            data: { username_edit_target: "input" },
                            autocomplete: "username" %>
                    <% end %>
                  </div>
                  <div class="shrink-0 translate-y-3" id="username_edit_wrap">
                    <button
                      id="username_edit_btn"
                      data-username-edit-target="editButton"
                      data-action="click->username-edit#edit"
                      type="button"
                      class="studs-nav-btn px-3 py-1.5 text-xs"
                      >
                      Edit
                    </button>
                    <div id="username_actions" data-username-edit-target="actions" class="hidden items-center gap-2">
                      <button type="submit" form="username_form" class="studs-btn-accent !px-4 !py-1.5">Save</button>
                      <button
                        data-action="click->username-edit#cancel"
                        type="button"
                        class="studs-nav-btn px-3 py-1.5 text-xs"
                        >
                        Cancel
                      </button>
                    </div>
                  </div>
                </div>
                <div class="flex items-center justify-between gap-4">
                  <div>
                    <div class="text-xs text-zinc-400">Email</div>
                    <div class="mt-1 text-sm font-medium text-zinc-100"><%= user.email %></div>
                  </div>
                  <div class="shrink-0 translate-y-3">
                    <button type="button" class="studs-nav-btn px-3 py-1.5 text-xs">Edit</button>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <!-- Security -->
          <div id="security" data-profile-nav-target="section">
            <div class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Security</div>
            <div class="mt-3 rounded-2xl border border-zinc-800 bg-zinc-900/40 p-5 space-y-4">
              <div class="flex items-center justify-between gap-4">
                <div>
                  <div class="text-sm text-zinc-200">Password</div>
                  <div class="text-xs text-zinc-500">Change the password you use to log in</div>
                </div>
                <div class="shrink-0">
                  <%= link_to edit_password_profile_path,
                        data: { turbo_frame: "profile_modal", turbo_prefetch: false },
                        class: "studs-btn-accent" do %>
                    Change password
                  <% end %>
                </div>
              </div>
            </div>
          </div>
          <!-- Account Removal -->
          <div id="account-removal">
            <div class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Account Removal</div>
            <div class="mt-3 rounded-2xl border border-zinc-800 bg-zinc-900/40 p-5 space-y-4">
              <div class="flex items-center justify-between gap-4">
                <div>
                  <div class="text-sm text-zinc-200">Delete</div>
                  <div class="text-xs text-zinc-500">Permanently delete your account</div>
                </div>
                <div class="shrink-0">
                  <%= link_to "Delete account",
                        delete_account_profile_path,
                        data: { turbo_frame: "profile_modal", turbo_prefetch: false },
                        class: "studs-btn-accent" %>
                </div>
              </div>
            </div>
          </div>
          <!-- Preferences / Theme -->
          <div id="preferences" data-profile-nav-target="section">
            <div class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Preferences</div>
            <div class="mt-3 rounded-2xl border border-zinc-800 bg-zinc-900/40 p-5">
              <div class="text-sm text-zinc-200 mb-1">Theme</div>
              <div class="text-xs text-zinc-500 mb-4">Choose a color theme for your planner</div>
              <% space_themes = %w[nebula aurora sunset] %>
              <% school_themes = %w[latech] %>
              <% classic_themes = User::THEMES - space_themes - school_themes %>
              <%= form_with url: theme_path, method: :patch, data: { turbo_frame: "_top" } do |f| %>
                <div class="text-[10px] font-semibold uppercase tracking-wider text-zinc-500 mb-2">Classic</div>
                <div class="flex flex-wrap gap-4">
                  <% classic_themes.each do |t| %>
                    <label class="cursor-pointer flex flex-col items-center gap-2 group">
                      <input type="radio" name="theme[theme]" value="<%= t %>"
                   <%= "checked" if current_user.theme == t %>
                   class="sr-only peer" />
                      <div class="h-9 w-9 rounded-full ring-2 ring-transparent peer-checked:ring-white peer-checked:scale-110 transition-all theme-swatch--<%= t %>"
                 title="<%= t.capitalize %>">
                      </div>
                      <span class="text-[10px] capitalize text-zinc-500 group-hover:text-zinc-300 transition">
                        <%= t %>
                      </span>
                    </label>
                  <% end %>
                </div>
                <div class="text-[10px] font-semibold uppercase tracking-wider text-zinc-500 mt-5 mb-2">Space</div>
                <div class="flex flex-wrap gap-4">
                  <% space_themes.each do |t| %>
                    <label class="cursor-pointer flex flex-col items-center gap-2 group">
                      <input type="radio" name="theme[theme]" value="<%= t %>"
                   <%= "checked" if current_user.theme == t %>
                   class="sr-only peer" />
                      <div class="h-9 w-9 rounded-full ring-2 ring-transparent peer-checked:ring-white peer-checked:scale-110 transition-all theme-swatch--<%= t %>"
                 title="<%= t.capitalize %>">
                      </div>
                      <span class="text-[10px] capitalize text-zinc-500 group-hover:text-zinc-300 transition">
                        <%= t %>
                      </span>
                    </label>
                  <% end %>
                </div>
                <div class="text-[10px] font-semibold uppercase tracking-wider text-zinc-500 mt-5 mb-2">School</div>
                <div class="flex flex-wrap gap-4">
                  <% school_themes.each do |t| %>
                    <label class="cursor-pointer flex flex-col items-center gap-2 group">
                      <input type="radio" name="theme[theme]" value="<%= t %>"
                   <%= "checked" if current_user.theme == t %>
                   class="sr-only peer" />
                      <div class="h-9 w-9 rounded-full ring-2 ring-transparent peer-checked:ring-white peer-checked:scale-110 transition-all theme-swatch--<%= t %>"
                 title="<%= t == "latech" ? "LaTech" : t.capitalize %>">
                      </div>
                      <span class="text-[10px] text-zinc-500 group-hover:text-zinc-300 transition">
                        <%= t == "latech" ? "LaTech" : t.capitalize %>
                      </span>
                    </label>
                  <% end %>
                </div>
                <%# CUSTOM THEMES %>
                <div class="text-[10px] font-semibold uppercase tracking-wider text-zinc-500 mt-5 mb-2">Custom</div>
                <div class="flex flex-wrap gap-4">
                  <% current_user.custom_themes.each do |name, variables| %>
                    <div class="relative flex flex-col items-center gap-2 group">
                      <label class="cursor-pointer flex flex-col items-center gap-2 group relative">
                        <input type="radio" name="theme[theme]" value="<%= name %>"
                    <%= "checked" if current_user.theme == name %>
                    class="sr-only peer" />
                        <div class="h-9 w-9 rounded-full ring-2 ring-transparent peer-checked:ring-white peer-checked:scale-110 transition-all overflow-hidden"
                  title="<%= name.capitalize %>"
                  style="background: conic-gradient(<%= variables['--studs-accent'] || '#888' %> 0deg 180deg, <%= variables['--studs-accent-secondary'] || '#555' %> 180deg 360deg);">
                        </div>
                        <span class="text-[10px] capitalize text-zinc-500 group-hover:text-zinc-300 transition">
                          <%= name %>
                        </span>
                      </label>
                      <%# Delete button — outside the label so the form is valid HTML %>
                      <%= link_to "✕", theme_path(id: name),
                      data: {
                        turbo_method: :delete,
                        turbo_confirm: "Delete \"#{name}\"?",
                        turbo_frame: "_top"
                      },
                      class: "absolute -top-1 -right-1 h-4 w-4 rounded-full bg-zinc-700 hover:bg-red-500 transition opacity-0 group-hover:opacity-100 flex items-center justify-center text-[8px] text-white leading-none" %>
                    </div>
                  <% end %>
                  <%# CREATE BUTTON ##################################################################################################################%>
                  <div class="flex flex-col items-center gap-2 group">
                    <%= link_to theme_path,
        data: { turbo_frame: "profile_modal", turbo_prefetch: false } do %>
                      <div class="h-9 w-9 rounded-full ring-2 ring-transparent group-hover:ring-white group-hover:scale-110 transition-all theme-swatch--slate flex items-center justify-center cursor-pointer"
         title="Create" />
                        <span class="[&>svg]:h-5 [&>svg]:w-5">
                          <%= icon "add-01-stroke-rounded" %>
                        </span>
                      </div>
                    <% end %>
                    <span class="text-[10px] capitalize text-zinc-500 group-hover:text-zinc-300 transition">
                      Create
                    </span>
                  </div>
                </div>
                <div class="mt-5 flex items-center justify-between">
                  <%= link_to reset_theme_path,
                        data: {
                          turbo_method: :delete,
                          turbo_confirm: "Reset to default green theme?",
                          turbo_frame: "_top"
                        },
                        class: "studs-nav-btn" do %>
                    Reset to default
                  <% end %>
                  <%= render Studs::PrimaryButtonComponent.new(label: "Save Theme", color: :accent, type: "submit") %>
                </div>
              <% end %>
            </div>
          </div>
        </section>
      </div>
    </div>
  </div>
<% end %>