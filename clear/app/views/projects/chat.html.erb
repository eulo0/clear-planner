<%= turbo_frame_tag "chat_drawer" do %>
  <%= turbo_stream_from @project, :project_messages %>
  <div class="h-full min-h-0 flex flex-col" style="background-color: var(--studs-panel-bg-2);">
    <!-- Header -->
    <div class="shrink-0 flex items-center justify-between px-4 py-3 backdrop-blur"
         style="border-bottom: 1px solid var(--studs-border); background-color: var(--studs-panel-header);">
      <div>
        <h1 class="text-base font-semibold text-zinc-100">Group Chat</h1>
        <p class="text-xs text-zinc-400 mt-0.5"><%= @project.title %></p>
      </div>
      <div class="flex items-center gap-2">
        <button type="button"
                data-action="click->chat-drawer#close"
          class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-zinc-400 hover:text-zinc-100 hover:bg-white/5 transition-colors"
          aria-label="Close chat">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
    <!-- Messages -->
    <div class="flex-1 min-h-0 overflow-y-auto px-4 py-4 flex flex-col gap-3 scrollbars" id="project_messages">
      <%= render @messages %>
    </div>
    <!-- Composer -->
    <%= render "project_messages/form", project: @project %>
  </div>
<% end %>
