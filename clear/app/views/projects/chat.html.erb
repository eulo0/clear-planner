<%= turbo_frame_tag "chat_drawer" do %>
  <%= turbo_stream_from @project, :project_messages %>
  <div class="h-full w-full flex flex-col">
    <!-- Header -->
    <div class="px-4 py-3 studs-topbar flex items-center justify-between">
      <div>
        <div class="text-sm font-semibold text-zinc-100">Group Chat</div>
        <div class="mt-0.5 text-xs text-zinc-400"><%= @project.title %></div>
      </div>
      <button
        type="button"
        class="studs-nav-btn"
        data-action="click->chat-drawer#close">
        Close
      </button>
    </div>
    <!-- Messages -->
    <div class="flex-1 min-h-0 overflow-auto px-3 py-3 space-y-2" id="project_messages">
      <%= render @messages %>
    </div>
    <!-- Form -->
    <%= render "project_messages/form", project: @project %>
  </div>
<% end %>