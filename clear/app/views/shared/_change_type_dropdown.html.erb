<%#
  Renders a "Change type" dropdown for an occurrence drawer/popover.
  Locals:
    source_type: "event" | "course" | "work_shift"
    record:      the source record (Event / Course / WorkShift)
    start_date:  date string for week refresh after convert
    variant:     :drawer (default) or :popover — controls trigger styling
%>
<%
  type_labels = { "event" => "Event", "course" => "Course", "work_shift" => "Work shift" }
  convert_url = case source_type
                when "event"      then convert_event_path(record)
                when "course"     then convert_course_path(record)
                when "work_shift" then convert_work_shift_path(record)
                end
  # Work shifts were retired from the UI: never offer "Work shift" as a convert target.
  options = type_labels.except(source_type, "work_shift")
  variant = local_assigns.fetch(:variant, :drawer)
  trigger_class = if variant == :popover
                    "inline-flex items-center gap-1.5 rounded-lg px-3 py-1.5 text-sm text-zinc-200 hover:bg-zinc-800 transition"
                  else
                    "studs-nav-btn inline-flex items-center gap-1"
                  end
  menu_align_class = variant == :popover ? "right-0" : "left-0"
%>
<div data-controller="delete-options" class="relative">
  <button
    type="button"
    data-action="delete-options#toggle"
    class="<%= trigger_class %>">
    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
    </svg>
    Change type
    <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
    </svg>
  </button>
  <div
    data-delete-options-target="menu"
    class="hidden absolute bottom-full <%= menu_align_class %> mb-1 w-44 rounded-xl border border-zinc-700 py-1 z-50"
    style="background-color: #18181b; box-shadow: 0 8px 30px rgba(0,0,0,0.7);">
    <% options.each do |type_key, label| %>
      <%= button_to label,
            convert_url,
            method: :post,
            params: { target_type: type_key, start_date: start_date },
            class: "w-full text-left px-3 py-2 text-sm text-zinc-200 hover:bg-zinc-800 transition" %>
    <% end %>
  </div>
</div>
