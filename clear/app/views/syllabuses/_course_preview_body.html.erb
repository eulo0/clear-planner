<% missing = @missing_fields || [] %>
<% label_base   = "text-[10px] font-bold uppercase tracking-widest mb-1.5" %>
<% label_ok     = "text-zinc-300" %>
<% label_ok_style = "color: var(--studs-accent); opacity: 0.8;" %>
<% label_miss   = "text-amber-200" %>
<% input_base   = "w-full rounded-2xl px-4 py-2.5 text-sm text-zinc-100 placeholder:text-zinc-600 bg-zinc-950/60 focus:outline-none focus:ring-2 transition-all duration-150 border" %>
<% input_ok     = "focus:ring-[var(--studs-accent)]" %>
<% input_ok_style = "border-color: var(--studs-border);" %>
<% input_miss   = "bg-amber-500/20 border border-amber-300/80 shadow-[0_0_0_1px_rgba(251,191,36,0.35)] focus:ring-amber-300/50" %>
<% if syllabus.parse_status.in?(%w[queued processing]) %>
  <div class="text-sm text-zinc-400">Parsing…</div>
<% elsif syllabus.parse_status == "failed" %>
  <div class="space-y-3">
    <div class="text-sm text-red-200">
      Parsing failed: <%= syllabus.parse_error %>
    </div>
    <%= link_to "Retry parsing",
          create_course_syllabus_path(syllabus),
          class: "studs-btn-accent",
          data: { turbo_method: :post, turbo_frame: "_top" } %>
  </div>
<% else %>
  <% parse_warning = syllabus.course_draft.is_a?(Hash) ? syllabus.course_draft["parse_warning"] : nil %>
  <% if parse_warning.present? %>
    <div class="mb-4 rounded-2xl px-4 py-3 text-sm text-amber-200 bg-amber-500/10 border border-amber-300/40">
      <%= parse_warning %>
    </div>
  <% end %>
  <%= form_with model: course,
        url: confirm_course_syllabus_path(syllabus),
        method: :post,
        data: { turbo_frame: "_top" } do |f| %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <% needs = missing.include?(:title) %>
      <div id="field_title">
        <div class="<%= "#{label_base} #{needs ? label_miss : label_ok}" %>" style="<%= (needs ? nil : label_ok_style) %>">Title</div>
        <%= f.text_field :title, class: "#{input_base} #{needs ? input_miss : input_ok}", style: (needs ? nil : input_ok_style) %>
      </div>
      <% needs = missing.include?(:code) %>
      <div id="field_code">
        <div class="<%= "#{label_base} #{needs ? label_miss : label_ok}" %>" style="<%= (needs ? nil : label_ok_style) %>">Code</div>
        <%= f.text_field :code, class: "#{input_base} #{needs ? input_miss : input_ok}", style: (needs ? nil : input_ok_style) %>
      </div>
      <% needs = missing.include?(:term) %>
      <div id="field_term">
        <div class="<%= "#{label_base} #{needs ? label_miss : label_ok}" %>" style="<%= (needs ? nil : label_ok_style) %>">Term</div>
        <%= f.text_field :term, class: "#{input_base} #{needs ? input_miss : input_ok}", style: (needs ? nil : input_ok_style) %>
      </div>
      <% needs = missing.include?(:professor) %>
      <div id="field_professor">
        <div class="<%= "#{label_base} #{needs ? label_miss : label_ok}" %>" style="<%= (needs ? nil : label_ok_style) %>">Professor</div>
        <%= f.text_field :professor, class: "#{input_base} #{needs ? input_miss : input_ok}", style: (needs ? nil : input_ok_style) %>
      </div>
      <% needs = missing.include?(:meeting_days) %>
      <div id="field_meeting_days">
        <div class="<%= "#{label_base} #{needs ? label_miss : label_ok}" %>" style="<%= (needs ? nil : label_ok_style) %>">Meeting Days</div>
        <%= f.text_field :meeting_days, class: "#{input_base} #{needs ? input_miss : input_ok}", style: (needs ? nil : input_ok_style) %>
      </div>
      <% needs = missing.include?(:location) %>
      <div id="field_location">
        <div class="<%= "#{label_base} #{needs ? label_miss : label_ok}" %>" style="<%= (needs ? nil : label_ok_style) %>">Location</div>
        <%= f.text_field :location, class: "#{input_base} #{needs ? input_miss : input_ok}", style: (needs ? nil : input_ok_style) %>
      </div>
      <% needs = missing.include?(:office) %>
      <div id="field_office">
        <div class="<%= "#{label_base} #{needs ? label_miss : label_ok}" %>" style="<%= (needs ? nil : label_ok_style) %>">Office</div>
        <%= f.text_field :office, class: "#{input_base} #{needs ? input_miss : input_ok}", style: (needs ? nil : input_ok_style), placeholder: "e.g. IESB 216" %>
      </div>
      <% needs = missing.include?(:office_hours) %>
      <div id="field_office_hours">
        <div class="<%= "#{label_base} #{needs ? label_miss : label_ok}" %>" style="<%= (needs ? nil : label_ok_style) %>">Office Hours</div>
        <%= f.text_field :office_hours, class: "#{input_base} #{needs ? input_miss : input_ok}", style: (needs ? nil : input_ok_style), placeholder: "e.g. MW 1:00 - 3:00 pm, by appointment" %>
      </div>
      <% needs = missing.include?(:start_time) %>
      <div id="field_start_time">
        <div class="<%= "#{label_base} #{needs ? label_miss : label_ok}" %>" style="<%= (needs ? nil : label_ok_style) %>">Start Time</div>
        <%= f.text_field :start_time, class: "#{input_base} #{needs ? input_miss : input_ok}", style: (needs ? nil : input_ok_style) %>
      </div>
      <% needs = missing.include?(:end_time) %>
      <div id="field_end_time">
        <div class="<%= "#{label_base} #{needs ? label_miss : label_ok}" %>" style="<%= (needs ? nil : label_ok_style) %>">End Time</div>
        <%= f.text_field :end_time, class: "#{input_base} #{needs ? input_miss : input_ok}", style: (needs ? nil : input_ok_style) %>
      </div>
      <% needs = missing.include?(:start_date) %>
      <div id="field_start_date">
        <div class="<%= "#{label_base} #{needs ? label_miss : label_ok}" %>" style="<%= (needs ? nil : label_ok_style) %>">Start Date*</div>
        <%= f.date_field :start_date, class: "#{input_base} #{needs ? input_miss : input_ok}", style: (needs ? nil : input_ok_style) %>
      </div>
      <% needs = missing.include?(:end_date) %>
      <div id="field_end_date">
        <div class="<%= "#{label_base} #{needs ? label_miss : label_ok}" %>" style="<%= (needs ? nil : label_ok_style) %>">End Date*</div>
        <%= f.date_field :end_date, class: "#{input_base} #{needs ? input_miss : input_ok}", style: (needs ? nil : input_ok_style) %>
      </div>
    </div>
    <%# Color picker %>
    <div class="mt-4 rounded-2xl p-4"
         style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg-2);">
      <div class="<%= label_base %> <%= label_ok %>" style="<%= label_ok_style %>">Course Color</div>
      <div class="flex items-center gap-3">
        <%= f.color_field :color,
              value: course.color.presence || "#34D399",
              class: "h-10 w-16 cursor-pointer rounded-xl border bg-zinc-950/40",
              style: "border-color: var(--studs-border);" %>
        <span class="text-xs text-zinc-500">Used as the calendar highlight for this course</span>
      </div>
    </div>
    <div class="mt-6">
      <%= f.submit "Create course", class: "studs-btn-accent" %>
    </div>
  <% end %>
<% end %>
