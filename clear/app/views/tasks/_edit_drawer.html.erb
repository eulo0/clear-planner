<%= turbo_frame_tag "event_drawer" do %>
  <div class="flex h-full flex-col">
    <div class="flex items-start justify-between border-b border-zinc-800 px-6 py-4">
      <div class="min-w-0">
        <div class="text-sm font-semibold text-zinc-100 truncate">Edit task</div>
        <div class="mt-1 text-xs text-zinc-500">Update details without leaving the page</div>
      </div>
      <div class="flex items-center gap-2">
        <%= button_to task_path(task),
              method: :delete,
              form: { data: { turbo_confirm: "Delete this task?", turbo_frame: "_top" } },
              class: "studs-nav-btn",
              style: "border-color: rgba(239,68,68,0.4); color: #fca5a5;" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
          Delete
        <% end %>
        <button
          type="button"
          data-action="drawer#close"
          class="studs-nav-btn">
          ✕
        </button>
      </div>
    </div>
    <div class="scrollbars min-h-0 flex-1 overflow-y-auto px-6 py-6">
      <%= render "tasks/form", task: task, courses: courses, grouped_course_items: grouped_course_items %>
    </div>
  </div>
<% end %>
