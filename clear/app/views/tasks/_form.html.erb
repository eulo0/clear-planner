<%# Shared task form (edit). Locals: task (Task), courses (Array), grouped_course_items (Hash). %>
<%= form_with model: task,
              url: task_path(task),
              method: :patch,
              class: "space-y-5",
              data: { drawer_close_on_success: "true" } do |f| %>
  <% if task.errors.any? %>
    <div class="rounded-2xl p-4 text-red-300"
         style="border: 1px solid rgba(239,68,68,0.3); background-color: rgba(127,29,29,0.2);">
      <p class="text-sm font-semibold mb-1">Please fix the following:</p>
      <ul class="list-disc pl-5 text-sm space-y-0.5">
        <% task.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <% label_classes = "block text-[10px] font-bold uppercase tracking-widest mb-1.5" %>
  <% label_style   = "color: var(--studs-accent); opacity: 0.8;" %>
  <% input_classes = "w-full rounded-2xl px-4 py-2.5 text-sm text-zinc-100 placeholder:text-zinc-600 " \
                     "bg-zinc-950/60 focus:outline-none focus:ring-2 transition-all duration-150 border" %>
  <% input_style   = "border-color: var(--studs-border); --tw-ring-color: var(--studs-accent);" %>
  <!-- Title -->
  <div>
    <%= f.label :title, class: label_classes, style: label_style do %>Title <span class="text-red-400">*</span><% end %>
    <%= f.text_field :title,
          required: true,
          class: input_classes,
          style: input_style,
          placeholder: "e.g. Draft the introduction" %>
  </div>
  <!-- Course + Course item (cascading) -->
  <% initial_items = task.course_item ? (grouped_course_items[task.course_item.course_id.to_s] || []) : [] %>
  <div data-controller="task-form"
       data-task-form-grouped-value="<%= grouped_course_items.to_json %>">
    <div class="grid grid-cols-2 gap-3">
      <div class="<%= initial_items.empty? ? 'col-span-2' : '' %>" data-task-form-target="courseCol">
        <%= f.label :course_item_id, "Course", class: label_classes, style: label_style %>
        <div data-action="dropdown:select->task-form#courseSelected">
          <%= render Studs::DropdownComponent.new(
            label: "No course (personal)",
            variant: :duration,
            name: "_course_filter",
            selected_value: task.course_item&.course_id&.to_s || "",
            items: [
              { label: "No course (personal)", value: "" },
              *courses.map { |c| { label: c[:name], value: c[:id].to_s } }
            ]
          ) %>
        </div>
      </div>
      <div class="<%= initial_items.empty? ? 'hidden' : '' %>" data-task-form-target="courseItemWrapper">
        <div class="<%= label_classes %>" style="<%= label_style %>">Course item</div>
        <%= render Studs::DropdownComponent.new(
          label: "— select course item —",
          variant: :duration,
          name: "task[course_item_id]",
          selected_value: task.course_item_id&.to_s,
          items: initial_items
        ) %>
      </div>
    </div>
  </div>
  <!-- Duration -->
  <div>
    <%= f.label :duration_minutes, "Duration", class: label_classes, style: label_style %>
    <%= render Studs::DropdownComponent.new(
      label: "— select duration —",
      variant: :duration,
      name: "#{f.object_name}[duration_minutes]",
      selected_value: task.duration_minutes,
      items: ApplicationHelper::DURATION_OPTIONS.map { |label, value| { label: label, value: value.to_s } }
    ) %>
  </div>
  <!-- When -->
  <div>
    <%= f.label :scheduled_at, "When", class: label_classes, style: label_style %>
    <%= f.datetime_local_field :scheduled_at,
          value: task.scheduled_at&.strftime("%Y-%m-%dT%H:%M"),
          class: input_classes,
          style: input_style %>
    <p class="mt-2 text-xs text-zinc-500">Leave blank to add to the backlog.</p>
  </div>
  <!-- Description -->
  <div>
    <%= f.label :description, class: label_classes, style: label_style %>
    <%= f.text_area :description,
          rows: 4,
          class: input_classes,
          style: "#{input_style} resize: vertical;",
          placeholder: "Optional notes…" %>
  </div>
  <!-- Color -->
  <div>
    <%= f.label :color, "Color", class: label_classes, style: label_style %>
    <%= f.color_field :color,
          value: task.color || "#34D399",
          class: "h-10 w-14 cursor-pointer rounded-xl border border-zinc-800 bg-zinc-950/40" %>
    <p class="mt-2 text-xs text-zinc-500">Defaults to the course color, or green for a personal task.</p>
  </div>
  <!-- Submit -->
  <div class="flex items-center gap-3 pt-4"
       style="border-top: 1px solid var(--studs-divider);">
    <button type="submit" class="studs-btn-accent">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
      </svg>
      Update task
    </button>
    <button type="button" class="studs-nav-btn" data-action="drawer#close">Cancel</button>
  </div>
<% end %>
