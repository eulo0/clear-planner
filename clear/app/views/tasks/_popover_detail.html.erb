<%= turbo_frame_tag "event_popover" do %>
  <% starts_at = task.scheduled_at&.in_time_zone %>
  <% ends_at   = starts_at ? starts_at + task.duration_minutes.minutes : nil %>
  <!-- Header -->
  <div class="flex items-center justify-between gap-3 px-4 pt-3 pb-2">
    <div class="flex items-center gap-2 min-w-0">
      <span class="h-3 w-3 shrink-0 rounded-full" style="background-color:<%= task.color.presence || '#34D399' %>"></span>
      <div class="text-sm font-semibold text-zinc-100 truncate">
        <%= task.title.presence || "(Untitled)" %>
      </div>
    </div>
    <button
      type="button"
      data-action="event-popover#close"
      class="shrink-0 inline-flex items-center justify-center h-6 w-6 rounded-lg text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800 transition text-xs">
      ✕
    </button>
  </div>
  <!-- Details -->
  <div class="px-4 pb-3 space-y-2 text-sm">
    <% if starts_at %>
      <div class="flex items-center gap-2 text-zinc-300">
        <svg class="h-4 w-4 shrink-0 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <span>
          <%= starts_at.strftime("%A, %b %-d") %> · <%= starts_at.strftime("%-I:%M %p") %><% if ends_at %> – <%= ends_at.strftime("%-I:%M %p") %><% end %> · <%= task.duration_minutes %> min
        </span>
      </div>
    <% end %>
    <% if (course = task.course_item&.course) %>
      <div class="flex items-center gap-2 text-zinc-300">
        <svg class="h-4 w-4 shrink-0 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
        </svg>
        <span><%= course.title %></span>
      </div>
    <% end %>
  </div>
  <!-- Actions -->
  <div class="flex items-center gap-2 px-4 pb-3 pt-1 border-t border-zinc-800">
    <%= link_to edit_task_path(task),
        data: { turbo: false },
        class: "inline-flex items-center gap-1.5 rounded-lg px-3 py-1.5 text-sm text-zinc-200 hover:bg-zinc-800 transition" do %>
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
      </svg>
      Edit
    <% end %>
    <%= button_to task_path(task),
        method: :delete,
        class: "inline-flex items-center gap-1.5 rounded-lg px-3 py-1.5 text-sm text-rose-300 hover:bg-rose-950/40 transition",
        form: { data: { turbo_confirm: "Delete this task?" } } do %>
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
      </svg>
      Delete
    <% end %>
  </div>
<% end %>
