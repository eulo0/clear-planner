<%# A single real task row. Locals:
      task        (Hash, required)
      course      (Hash|nil, optional) — show a course chip when present
      personal    (Bool, optional)     — show a "Personal" chip when true and no course
      extra_class (String, optional)   — extra classes on the row (e.g. "tsk-missed-row")
   The checkbox toggles completion client-side via the tasks-page controller;
   the row is keyed by data-task-id so every occurrence stays in sync. %>
<% done = task[:done] %>
<% est = task[:estimate] %>
<% est_label = est < 60 ? "#{est} min" : "#{est / 60}h#{est % 60 > 0 ? " #{est % 60}m" : ""}" %>
<% course = local_assigns[:course] %>
<div class="tsk-row <%= local_assigns[:extra_class] %>" data-task-id="<%= task[:id] %>">
  <button type="button" class="tsk-cbx <%= "is-done" if done %>" data-action="click->tasks-page#toggleDone" aria-label="Toggle complete">
    <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 5 5 9-11"/></svg>
  </button>
  <div class="min-w-0 flex-1">
    <div class="tsk-row-title text-sm font-medium <%= done ? "text-zinc-500 line-through" : "text-zinc-100" %>"><%= task[:title] %></div>
    <div class="mt-1.5 flex flex-wrap items-center gap-2">
      <% if course %>
        <span class="tsk-chip course" style="--cc:<%= course[:color] %>;"><span class="dot"></span><%= course[:code] %></span>
      <% elsif local_assigns[:personal] %>
        <span class="tsk-chip course" style="--cc:#a1a1aa;"><span class="dot"></span>Personal</span>
      <% end %>
      <span class="tsk-chip est">
        <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="8"/><path d="M12 8v4.5l3 2"/></svg>
        <%= est_label %>
      </span>
      <% if task[:late_days] %>
        <span class="tsk-chip due overdue">Due <%= task[:due] %> · <%= task[:late_days] %> <%= "day".pluralize(task[:late_days]) %> late</span>
      <% elsif task[:overdue] %>
        <span class="tsk-chip due overdue">Overdue</span>
      <% end %>
    </div>
  </div>
  <div class="flex shrink-0 items-center gap-2">
    <% unless local_assigns[:hide_schedule] %>
      <% if task[:scheduled].present? %>
        <span class="tsk-chip sched">
          <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="8"/><path d="M12 8v4.5l3 2"/></svg>
          <%= task[:scheduled] %>
        </span>
      <% elsif local_assigns[:status_only] %>
        <span class="tsk-chip unsched">Unscheduled</span>
      <% else %>
        <button type="button" class="tsk-btn-sched">
          <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="8"/><path d="M12 8v4.5l3 2"/></svg>
          Schedule
        </button>
      <% end %>
    <% end %>
    <button type="button" class="tsk-iconbtn" aria-label="More">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5.5" r="1.4"/><circle cx="12" cy="12" r="1.4"/><circle cx="12" cy="18.5" r="1.4"/></svg>
    </button>
  </div>
</div>
