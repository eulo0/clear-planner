<div class="min-h-screen">
    <main class="min-w-0 flex-1 px-6 py-6">
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-2xl border border-zinc-800 bg-zinc-900/40 p-5">
          <div class="text-xs text-zinc-400">Primary button</div>
          <div class="mt-3 flex flex-wrap gap-2">
            <%= render Studs::PrimaryButtonComponent.new(label: "Orange (default)", color: :orange) %>
            <%= render Studs::PrimaryButtonComponent.new(label: "Zinc", color: :zinc) %>
            <%= render Studs::PrimaryButtonComponent.new(label: "Blue", color: :blue) %>
            <%= render Studs::PrimaryButtonComponent.new(label: "Emerald", color: :emerald) %>
            <%= render Studs::PrimaryButtonComponent.new(label: "Red", color: :red) %>
          </div>
        </div>
        <div class="rounded-2xl border border-zinc-800 bg-zinc-900/40 p-5">
          <div class="text-xs text-zinc-400">Secondary colors</div>
          <div class="mt-3 flex flex-wrap gap-2">
            <%= render Studs::SecondaryButtonComponent.new(label: "Zinc", color: :zinc, size: :sm) %>
            <%= render Studs::SecondaryButtonComponent.new(label: "Orange", color: :orange, size: :sm) %>
            <%= render Studs::SecondaryButtonComponent.new(label: "Blue", color: :blue, size: :sm) %>
            <%= render Studs::SecondaryButtonComponent.new(label: "Emerald", color: :emerald, size: :sm) %>
            <%= render Studs::SecondaryButtonComponent.new(label: "Red", color: :red, size: :sm) %>
          </div>
        </div>
        <div class="rounded-2xl border border-zinc-800 bg-zinc-900/40 p-5">
          <div class="text-xs text-zinc-400">Secondary sizes</div>
          <div class="mt-3 flex flex-wrap items-center gap-2">
            <%= render Studs::SecondaryButtonComponent.new(label: "XS", size: :xs, color: :zinc) %>
            <%= render Studs::SecondaryButtonComponent.new(label: "SM", size: :sm, color: :zinc) %>
            <%= render Studs::SecondaryButtonComponent.new(label: "MD", size: :md, color: :zinc) %>
            <%= render Studs::SecondaryButtonComponent.new(label: "LG", size: :lg, color: :zinc) %>
          </div>
        </div>
        <div class="rounded-2xl border border-zinc-800 bg-zinc-900/40 p-5 lg:col-span-3">
          <div class="text-xs text-zinc-400">Nav link component</div>
          <div class="mt-3 grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
            <%= render Studs::LeftNavLinkComponent.new(label: "Active", path: "#", icon_name: "search-01-stroke-rounded", active: true) %>
            <%= render Studs::LeftNavLinkComponent.new(label: "Inactive", path: "#", icon_name: "search-01-stroke-rounded", active: false) %>
          </div>
        </div>
        <div class="rounded-2xl border border-zinc-800 bg-zinc-900/40 p-5">
          <div class="text-xs text-zinc-400">Input & Dropdown</div>
          <div class="mt-3 flex flex-col gap-3">
            <%= render Studs::DropdownComponent.new(
              label: "Weekly",
              variant: :dashboard_view,
              name: "ui_dashboard_view",
              selected_value: "weekly",
              items: [
                { label: "Weekly", value: "weekly" },
                { label: "Monthly", value: "monthly" },
              ]
            ) %>
            <%= render Studs::DropdownComponent.new(
              label: "All Types",
              variant: :agenda_filter,
              name: "ui_agenda_type",
              selected_value: "",
              items: [
                { label: "All Types", value: "" },
                { label: "Events", value: "event" },
                { label: "Courses", value: "course" },
                { label: "Course Items", value: "course_item" },
                { label: "Work Shifts", value: "work_shift" }
              ]
            ) %>
            <%= render Studs::DropdownComponent.new(
              label: "— select duration —",
              variant: :duration,
              name: "ui_duration",
              items: [
                { label: "15 minutes", value: "15" },
                { label: "30 minutes", value: "30" },
                { label: "45 minutes", value: "45" },
                { label: "1 hour", value: "60" },
                { label: "1 hour 30 minutes", value: "90" }
              ]
            ) %>
            <%= render Studs::DropdownComponent.new(
              label: "Current Calendar",
              variant: :analytics_compare,
              name: "ui_analytics_compare",
              items: [
                { label: "Current Calendar", value: "current calendar" },
                { label: "Draft 1", value: "draft 1"},
              ]
            ) %>
          </div>
          <div class="mt-3">
           <%= render Studs::InputBoxComponent.new(name: "email", placeholder: "Input Box", color: :zinc, size: :xs) %>
          </div>
        </div>
        <div class="lg:col-span-2">
          <div class="w-full flex-none rounded-none p-0 h-[calc(100vh-6rem)] overflow-hidden"
               style="border: 1px solid var(--studs-border); background-color: var(--studs-sidebar-bg);">
            <div class="h-full min-h-0 flex flex-col" style="background-color: var(--studs-panel-bg-2);">
            <div class="shrink-0 flex items-center justify-between px-4 py-3 backdrop-blur"
                 style="border-bottom: 1px solid var(--studs-border); background-color: var(--studs-panel-header);">
              <div>
                <h1 class="text-base font-semibold text-zinc-100">Assistant</h1>
                <p class="text-xs text-zinc-400 mt-0.5">Ask questions, explore scenarios, and compare schedule what-ifs.</p>
              </div>
              <div class="flex items-center gap-2">
                <span class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-xs font-medium"
                      style="border: 1px solid rgba(34, 197, 94, 0.3); background-color: rgba(34, 197, 94, 0.1); color: #86efac;">
                  <span class="h-1.5 w-1.5 rounded-full"
                        style="background-color: #22c55e; box-shadow: 0 0 8px rgba(34, 197, 94, 0.7);"></span>
                  Online
                </span>
                <button type="button"
                        class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-zinc-400 hover:text-zinc-100 hover:bg-white/5 transition-colors"
                        aria-label="Close chat">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                  </svg>
                </button>
              </div>
            </div>
            <div class="shrink-0 px-4 pt-3">
              <div class="rounded-xl px-3 py-2 text-xs text-zinc-300"
                   style="border: 1px solid var(--studs-border); background-color: var(--studs-panel-bg-2);">
                <div class="flex items-center gap-3">
                  <span class="opacity-80">MIN</span>
                  <div class="h-1.5 flex-1 rounded-full bg-zinc-700/60"></div>
                  <span class="font-semibold text-emerald-300">0 / 10</span>
                  <span class="opacity-50">|</span>
                  <span class="opacity-80">DAY</span>
                  <div class="h-1.5 flex-1 rounded-full bg-zinc-700/60"></div>
                  <span class="font-semibold text-emerald-300">0 / 250</span>
                </div>
              </div>
            </div>
            <div id="ui_ai_chat_messages" class="flex-1 min-h-0 overflow-y-auto px-4 pt-4 pb-32 flex flex-col justify-start gap-3 scrollbars">
              <% @event = current_user.events.new(color: "#34D399") %>
              <% demo_messages = [
                { "role" => "user", "content" => "Create me an event" },
                { "role" => "assistant", "content" => "Got it. Fill this out and I can continue." }
              ] %>
              <% demo_messages.each do |message| %>
                <%= render "ai_chat/message", m: message %>
              <% end %>
              <%= render "ai_chat/ai_create_form", event: @event %>
              <%= render "ai_chat/draft_select_form" %>
            </div>
            <div class="shrink-0 px-4 py-3 backdrop-blur"
                 style="border-top: 1px solid var(--studs-border); background-color: var(--studs-panel-header);">
              <div class="flex items-center gap-2">
                <textarea
                  id="ui_ai_chat_input"
                  rows="3"
                  placeholder="Ask a what-if… (Shift+Enter for new line)"
                  class="flex-1 w-full resize-none rounded-2xl px-4 py-3 text-sm text-zinc-100 placeholder:text-zinc-500 focus:outline-none transition"
                  style="background-color: color-mix(in srgb, var(--studs-panel-bg) 60%, #09090b); border: 1px solid var(--studs-border);"></textarea>
                <button type="button"
                        class="shrink-0 inline-flex items-center justify-center rounded-xl w-9 h-9 transition hover:brightness-110 focus:outline-none"
                        style="background-color: var(--studs-accent); box-shadow: 0 0 12px color-mix(in srgb, var(--studs-accent) 40%, transparent);">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 19V5m0 0l-7 7m7-7l7 7"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>
