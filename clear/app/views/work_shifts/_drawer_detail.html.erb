<%= turbo_frame_tag "event_drawer" do %>
  <% color = work_shift.color.presence || "#34D399" %>
  <% start_date_value = params[:start_date].presence || work_shift.start_date %>
  <% date_label = nil %>
  <% if start_date_value.present? %>
    <% begin %>
      <% date_label = Date.parse(start_date_value.to_s).strftime("%A, %b %-d") %>
    <% rescue ArgumentError %>
      <% date_label = nil %>
    <% end %>
  <% end %>

  <div class="flex h-full flex-col">
    <div class="flex items-start justify-between border-b border-zinc-800 px-6 py-4">
      <div class="min-w-0">
        <div class="flex items-center gap-2">
          <span class="h-3 w-3 rounded-full" style="background-color:<%= color %>"></span>
          <div class="text-sm font-semibold text-zinc-100 truncate">
            <%= work_shift.title.presence || "(Untitled)" %>
          </div>
        </div>
        <div class="mt-1 text-xs text-zinc-500">Work shift details</div>
      </div>

      <button
        type="button"
        data-action="drawer#close"
        class="studs-nav-btn">
        ✕
      </button>
    </div>

    <div class="scrollbars min-h-0 flex-1 overflow-y-auto px-6 py-6 space-y-4">
      <div class="rounded-2xl border border-zinc-800 bg-zinc-950/40 p-4">
        <div class="text-xs text-zinc-400">When</div>
        <div class="mt-1 text-sm text-zinc-100">
          <% if date_label.present? %>
            <%= date_label %> ·
          <% end %>
          <%= work_shift.start_time&.strftime("%-I:%M %p") || "Time not set" %>
          <% if work_shift.end_time.present? %>
            – <%= work_shift.end_time.strftime("%-I:%M %p") %>
          <% end %>
        </div>
      </div>

      <div class="rounded-2xl border border-zinc-800 bg-zinc-950/40 p-4">
        <div class="text-xs text-zinc-400">Location</div>
        <div class="mt-1 text-sm text-zinc-100"><%= work_shift.location.presence || "—" %></div>
      </div>

      <div class="rounded-2xl border border-zinc-800 bg-zinc-950/40 p-4">
        <div class="text-xs text-zinc-400">Description</div>
        <div class="mt-1 text-sm text-zinc-100 whitespace-pre-wrap"><%= work_shift.description.presence || "—" %></div>
      </div>

      <div class="rounded-2xl border border-zinc-800 bg-zinc-950/40 p-4">
        <div class="text-xs text-zinc-400">Repeat</div>
        <% if work_shift.recurring? %>
          <div class="mt-1 text-sm text-zinc-100">
            Weekly on <%= work_shift.repeat_days_labels.presence || "—" %>
            <% if work_shift.repeat_until.present? %>
              until <%= work_shift.repeat_until.strftime("%b %-d, %Y") %>
            <% end %>
          </div>
        <% else %>
          <div class="mt-1 text-sm text-zinc-100">No</div>
        <% end %>
      </div>
    </div>

    <div class="shrink-0 border-t border-zinc-800 bg-zinc-950/60 px-6 py-4">
      <div class="flex items-center gap-2">
        <%= link_to edit_work_shift_path(work_shift, start_date: start_date_value),
                    data: { turbo_frame: "event_drawer", turbo_prefetch: false },
                    class: "studs-nav-btn" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
          </svg>
          Edit
        <% end %>

        <%= button_to work_shift_path(work_shift, start_date: start_date_value),
              method: :delete,
              class: "studs-nav-btn",
              style: "border-color: rgba(239,68,68,0.4); color: #fca5a5;",
              form: { data: { turbo_confirm: "Delete this shift?" } } do %>
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
          Delete
        <% end %>
      </div>
    </div>
  </div>
<% end %>
