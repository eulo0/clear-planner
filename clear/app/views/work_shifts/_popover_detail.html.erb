<%= turbo_frame_tag "event_popover" do %>
  <% work_shift_identifier = local_assigns[:work_shift_identifier] || work_shift %>
  <!-- Header -->
  <div class="flex items-center justify-between gap-3 px-4 pt-3 pb-2">
    <div class="flex items-center gap-2 min-w-0">
      <span class="h-3 w-3 shrink-0 rounded-full" style="background-color:<%= work_shift.color.presence || '#34D399' %>"></span>
      <div class="text-sm font-semibold text-zinc-100 truncate">
        <%= work_shift.title.presence || "(Untitled)" %>
      </div>
    </div>
    <button
      type="button"
      data-action="event-popover#close"
      class="shrink-0 inline-flex items-center justify-center h-6 w-6 rounded-lg text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800 transition text-xs">
      ✕
    </button>
  </div>

  <!-- Details -->
  <div class="px-4 pb-3 space-y-2 text-sm">
    <% if work_shift.start_time.present? %>
      <div class="flex items-center gap-2 text-zinc-300">
        <svg class="h-4 w-4 shrink-0 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <span>
          <%= work_shift.start_time.strftime("%-I:%M %p") %>
          <% if work_shift.end_time.present? %> – <%= work_shift.end_time.strftime("%-I:%M %p") %><% end %>
        </span>
      </div>
    <% end %>

    <% if work_shift.location.present? %>
      <div class="flex items-center gap-2 text-zinc-300">
        <svg class="h-4 w-4 shrink-0 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        <span><%= work_shift.location %></span>
      </div>
    <% end %>

    <% if work_shift.description.present? %>
      <div class="flex items-start gap-2 text-zinc-300">
        <svg class="h-4 w-4 shrink-0 mt-0.5 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h10"/>
        </svg>
        <span class="line-clamp-3 whitespace-pre-wrap"><%= work_shift.description %></span>
      </div>
    <% end %>

    <% if Array(work_shift.repeat_days).any? %>
      <div class="flex items-center gap-2 text-zinc-300">
        <svg class="h-4 w-4 shrink-0 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
        </svg>
        <span>
          Weekly on <%= work_shift.repeat_days_labels %>
          <% if work_shift.repeat_until.present? %>
            until <%= work_shift.repeat_until.strftime("%b %-d, %Y") %>
          <% end %>
        </span>
      </div>
    <% end %>
  </div>

  <!-- Actions -->
  <div class="flex items-center gap-2 px-4 pb-3 pt-1 border-t border-zinc-800">
    <%= link_to edit_work_shift_path(work_shift_identifier, start_date: start_date),
          data: { turbo: false },
          class: "inline-flex items-center gap-1.5 rounded-lg px-3 py-1.5 text-sm text-zinc-200 hover:bg-zinc-800 transition" do %>
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
      </svg>
      Edit
    <% end %>

    <%= button_to work_shift_path(work_shift_identifier, start_date: start_date),
          method: :delete,
          class: "inline-flex items-center gap-1.5 rounded-lg px-3 py-1.5 text-sm text-rose-300 hover:bg-rose-950/40 transition",
          form: { data: { turbo_confirm: "Delete this shift?" } } do %>
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
      </svg>
      Delete
    <% end %>
  </div>
<% end %>
